  {
    "id": "magic_wizard_blinding_flash",
    "name": "Blinding Flash",
    "description": "This invocation creates a sudden burst of intense white light, temporarily blinding everyone in its ten foot (3.0 m) radius. Victims are blinded for one to four (1D4) melee rounds, with a penalty of -5 to strike, and -10 to parry and dodge. The chance of falling is 50% every 10 ft (3.0 m). The magic can be cast up to 60 ft (18.3 m) away. Saving throw is standard; those who successfully save versus magic are not blinded.",
    "gameSystems": [
      "nightbane"
    ],
    "sources": [
      {
        "gameSystem": "nightbane",
        "reference": "Nightbane RPG",
        "pageNumber": 128
      }
    ],
    "spellLevel": 1,
    "magicKind": "invocation",
    "spellStrengthBase": 12,
    "tags": [
      "offensive",
      "light"
    ],
    "ppe": {
      "baseActivation": 1
    },
    "range": {
      "summary": "10 ft (3.0 m) radius; up to 60 ft (18.3 m) away."
    },
    "duration": {
      "summary": "1D4 melee rounds.",
      "kind": "melee_round",
      "dice": "1D4"
    },
    "save": {
      "summary": "Standard",
      "saveKind": "standard"
    },
    "inflictedModifiers": {
      "statusEffects": [
        "blinded"
      ],
      "combatModifiers": {
        "strike": -5,
        "parry": -10,
        "dodge": -10,
        "notes": "The chance of falling is 50% every 10 ft (3.0 m) moved."
      }
    }
  },
