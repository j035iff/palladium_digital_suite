  {
    "kind": "weapon_proficiency",
    "weaponProficiencyCategory": "ancient",
    "id": "wp_paired_weapons",
    "name": "W.P. Paired Weapons",
    "gameSystems": [
      "nightbane"
    ],
    "description": "A tactic in which a one-handed weapon is held in each hand (up to four) to be used in any combination of combat moves simultaneously. Negates the standard off-hand penalty for weapons in which the character is already proficient. Notes: Requires a W.P. in the specific weapons being used. Two-handed weapons or weapons that are too large/heavy negate this skill. Designed for melee weapons; when shooting two guns at once, there is a penalty of -2 to strike with the regular hand and -6 to strike with the off-hand. A character using both attacks simultaneously is vulnerable to attack from a second opponent. Four-armed characters only need to take this skill once.",
    "pairedWeapons": {
      "summary": "Paired weapon fighting style; see description and special maneuvers for detailed rules."
    },
    "specialManeuvers": [
      {
        "name": "Simultaneous Strike and Parry",
        "description": "Strike and parry simultaneously. Performs two actions for every one melee action/attack. Requires available attacks to strike."
      },
      {
        "name": "Twin Strike",
        "description": "Twin, simultaneous strikes against the same target. Both weapons hit the same opponent at once, making it ONE melee attack/action (roll only once to strike with both weapons). The defender can only parry one unless they also use paired weapons/shield."
      },
      {
        "name": "Strike Multiple Targets",
        "description": "Strike two different targets (or strike one and parry another incoming attack), simultaneously; both must be within reach."
      },
      {
        "name": "Simultaneous Parries",
        "description": "Parry two different attackers, one with each hand."
      }
    ],
    "sources": [
      {
        "gameSystem": "nightbane",
        "reference": "Nightbane Survival Guide",
        "pageNumber": 59
      }
    ],
    "categories": [
      "Weapon Proficiencies",
      "Ancient"
    ]
  },
  {
