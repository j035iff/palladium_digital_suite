    {
      "id": "nightmare_floating",
      "name": "Floating",
      "tableCategory": "Nightmare",
      "description": "Hovering 1–3 ft off the ground; ghostly, terror-pale appearance with hair and clothing always fluttering. Cannot fall from heights over 60 ft but takes full impact damage from strikes and vehicles.",
      "statModifiers": {
        "me": { "dice": "-1D4" },
        "ma": { "dice": "-1D4" },
        "spd": { "percent": -50 },
        "hf": { "flat": 1 },
        "rollWithPunch": { "flat": 2 },
        "pullPunch": { "flat": 2 }
      },
      "skillModifiers": {
        "specificSkillOverrides": [
          { "targetType": "skill_id", "targetValue": "skill_prowl", "modifierPercent": 20 }
        ]
      },
      "customOneOffs": [
        "+10% to Intimidation rolls.",
        "Hover/float 1–3 ft (0.3–0.9 m); max Spd equals Spd attribute; no fall damage; no footprints/tracks; avoids pressure plates; still vulnerable to motion/heat detection.",
        "Fear of Heights plus two other phobias or random insanities (player picks category, rolls on Nightbane RPG p. 44)."
      ],
      "gameSystems": ["nightbane"],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane® Dark Designs Sourcebook (WB6)",
          "pageNumber": 41
        }
      ]
    },
