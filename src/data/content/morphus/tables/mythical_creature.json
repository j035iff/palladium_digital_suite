    {
      "id": "mythical_creature_bigfoot_wendigo_yeti",
      "name": "Bigfoot/Wendigo/Yeti",
      "tableCategory": "Mythical Creature",
      "description": "Sasquatch-type Morphus: 7–8 ft (2.1–2.4 m) tall, shaggy fur, primate-like face, human-adapted legs. Often a nature lover or environmentalist.",
      "statModifiers": {
        "ps": { "dice": "1D6" },
        "pe": { "dice": "1D6" },
        "spd": { "dice": "2D6" },
        "sdc": { "dice": "1D4x10" },
        "iq": { "flat": -1 },
        "ma": { "flat": -1 },
        "pb": { "flat": -2 },
        "perception": { "flat": 2 }
      },
      "sensory": {
        "nightvisionRangeFlatBonus": 1000,
        "seeInvisible": false
      },
      "skillModifiers": {
        "specificSkillOverrides": [
          { "targetType": "skill_id", "targetValue": "skill_prowl", "modifierPercent": 20 },
          { "targetType": "skill_id", "targetValue": "skill_camouflage", "modifierPercent": 20 },
          { "targetType": "skill_id", "targetValue": "skill_climbing", "modifierPercent": 20 },
