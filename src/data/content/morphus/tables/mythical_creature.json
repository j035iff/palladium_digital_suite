    {
      "id": "mythical_creature_bigfoot",
      "name": "Bigfoot/Wendigo/Yeti",
      "tableCategory": "Mythical Creature",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Dark Designs (WB6)",
          "pageNumber": 37
        }
      ],
      "description": "The Sasquatch-type Morphus is a tall humanoid with thick, shaggy fur covering most of the body. The facial features are reminiscent to primates such as chimpanzees, as are the long, powerful limbs. The legs and feet, however, are better suited for walking and running than climbing through trees, and shaped more like a modern human's.",
