          { "targetType": "skill_id", "targetValue": "skill_undercover_ops", "modifierPercent": -30 }
        ]
      },
      "customOneOffs": [
        "+20% to Prowl, Camouflage, and Climbing in wooded environments (modeled as flat skill bonuses above).",
        "+10% to all Wilderness skills (partially modeled via Wilderness Survival).",
        "Automatically starts with the Leave No Trace Talent.",
        "Custom clothing required; tends to eschew high-tech gadgets. Impersonation at -30% in this Morphus."
      ],
      "gameSystems": ["nightbane"],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane® Dark Designs Sourcebook (WB6)",
