    {
      "id": "fantasy_branded_with_magic_symbols",
      "name": "Branded with Magic Symbols",
      "tableCategory": "Fantasy",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane Survival Guide",
          "pageNumber": 90
        }
      ],
      "description": "The Morphus is a muscular humanoid with dark skin (gray, brown, red, or purple), and a face covered in magic symbols and runes. Every inch of the body, from head to toe, is covered with the symbols. All are raised as if branded onto his skin[cite: 10].",
