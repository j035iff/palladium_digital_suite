          "isAdditiveToHth": true,
          "strikeBonus": 1,
          "parryBonus": 1
        }
      ],
      "customOneOffs": [
        "The dice can also be removed from the bag and scattered on hard ground or floors to discourage pursuit[cite: 7]."
      ]
    },
