    {
      "id": "hobbyist_video_games",
      "name": "Video Games",
      "tableCategory": "Hobbyist",
      "description": "The Morphus resembles a video-game character and wears VR goggles that make the real world feel like a game. A wireless controller can bestow video-game powers with the press of a button.",
      "statModifiers": {
        "iq": {
          "flat": 1
        },
        "ma": {
          "flat": -2
        }
      },
      "saveModifiers": {
        "insanity": 2
      },
      "limbDurability": [
        {
          "limbName": "Video Game Controller",
          "quantity": 1,
          "sdc": 10,
          "hp": 0,
          "calledShotPenalty": -4
        }
      ],
      "activatedAbilities": [
        {
          "abilityName": "Hyper-Combat",
          "chargesPerPeriod": 3,
          "resetPeriod": "hourly",
          "durationFormula": "1 melee round",
          "statModifiers": {
            "apm": {
              "flat": 2
            },
            "spd": {
              "percent": 20
            },
            "strike": {
              "flat": 1
            },
            "parry": {
              "flat": 1
            },
            "dodge": {
              "flat": 1
            },
            "disarm": {
              "flat": 1
            }
          }
        },
        {
          "abilityName": "Force Field",
          "chargesPerPeriod": 3,
          "resetPeriod": "hourly",
          "durationFormula": "1 melee round"
        },
        {
          "abilityName": "Life Points",
          "chargesPerPeriod": 3,
          "resetPeriod": "hourly",
          "durationFormula": "instant"
        }
      ],
      "customOneOffs": [
        "Three video-game powers (+1 per level) may be activated each hour; duration is one melee round (15 seconds) unless noted instant.",
        "Permanent P.P.E. base is reduced by 2D6.",
        "Powers include: Demon Death Strike (double damage vs demons/Nightlands creatures on one attack), Float (safe descent/leap, water run), Force Field (60 +10 S.D.C. per level for 1 round), Life Points (restore 3D6+18 H.P. or S.D.C. to self), Heal Other (3D6+18 to one touched), Impervious to Fire, Impervious to Magic, Jump (+3 dodge for 1 round), See the Invisible, Energy Bolt (4D6+2/level, 600 ft +100 ft/level), Returning Melee Weapon (1 round).",
        "If the controller is lost or destroyed: lose 2D4 S.D.C. (or H.P. if S.D.C. depleted), -1 attack per melee, -10% all skills until Facade for one hour then resume Morphus.",
        "Controller has 10 S.D.C. and is only damaged on a Called Shot."
      ],
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane® Dark Designs Sourcebook (WB6)",
          "pageNumber": 35
        }
      ]
    },
