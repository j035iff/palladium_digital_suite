    {
      "id": "hobbyist_saddle",
      "name": "Saddle",
      "tableCategory": "Hobbyist",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Dark Designs (WB6)",
          "pageNumber": 36
        }
      ],
      "description": "In Morphus, the character may have a cowboy esthetic to his appearance and has a riding saddle either draped over one shoulder or worn on his own back, fastened to him with straps of rawhide or belts. Any Nightbane capable of running on all fours can let other people ride in the saddle.",
      "statModifiers": {
        "ps": {
          "flat": 2
        },
        "pe": {
          "flat": 2
        },
        "me": {
          "flat": -1
        },
        "sdc": {
          "dice": "3D6"
        },
        "rollWithPunch": {
          "flat": -3
        }
      },
      "skillModifiers": {
        "specificSkillOverrides": [
          {
            "targetType": "skill_id",
            "targetValue": "horsemanship",
            "modifierPercent": 10
          }
        ]
      },
      "customOneOffs": [
        "Anyone riding in the saddle receives +1 to initiative, +2 to damage with melee weapon, and +1 to dodge regardless of training or experience in mounted combat."
      ]
    },
