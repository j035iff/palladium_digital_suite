    {
      "id": "hobbyist_card_deck",
      "name": "Card Deck",
      "tableCategory": "Hobbyist",
      "description": "The Morphus bears a playing-card motif and carries a deck of tough, flexible cards in a case on belt or pocket. When the deck is used up, a new deck appears automatically.",
      "statModifiers": {
        "iq": {
          "flat": 1
        },
        "pp": {
          "flat": 1
        },
        "me": {
          "flat": -1
        }
      },
      "weaponClassBonuses": {
        "thrown": {
          "flat": 2
        }
      },
      "naturalWeapons": [
        {
          "limbType": "misc_limbs",
          "label": "Playing Card",
          "damageFormula": "1D6",
          "isAdditiveToHth": false
        }
      ],
      "gimmickInventory": [
        {
          "itemName": "Playing Card Deck",
          "sdc": 10,
          "effectFormula": "1D6 per card (2D6 for aces and face cards); thrown range 60 feet (18.3 m)",
          "regenerationRule": "per_transformation",
          "traitFlags": [
            "infinite_ammo"
          ]
        }
      ],
      "customOneOffs": [
        "Thrown cards: aces and face cards inflict 2D6 damage.",
        "On a Natural 19 or 20 with thrown cards or other thrown weapons, add +2D6 damage.",
        "Permanent P.P.E. base is reduced by 1D6+2."
      ],
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane® Dark Designs Sourcebook (WB6)",
          "pageNumber": 35
        }
      ]
