    {
      "id": "hobbyist_card_deck",
      "name": "Card Deck",
      "tableCategory": "Hobbyist",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Dark Designs (WB6)",
          "pageNumber": 35
        }
      ],
      "description": "The Nightbane's Morphus has a playing card motif element which may be subtle or unmistakable[cite: 7]. This Morphus also comes with a deck of playing cards carried in a small case, usually hooked to a belt or held in a pocket[cite: 7]. Unlike normal cards, they are tough and flexible enough to be used as thrown weapons[cite: 7]. When the deck is used up, the Nightbane reaches back into his pocket or carrying case and pulls out a new deck; never runs out[cite: 7].",
      "statModifiers": {
        "iq": {
          "flat": 1
        },
        "pp": {
          "flat": 1
        },
        "me": {
          "flat": -1
        },
        "ppe": {
          "dice": "-1D6-2"
        }
      },
      "weaponClassBonuses": {
        "thrown": {
          "flat": 2
        }
      },
      "gimmickInventory": [
        {
          "itemName": "Playing Cards",
          "sdc": 1,
          "effectFormula": "1D6",
          "rangeFeet": 60,
          "traitFlags": [
            "infinite_ammo"
          ],
          "customOneOffs": [
            "Aces and face cards do 2D6 damage[cite: 7]."
          ]
        }
      ],
      "customOneOffs": [
        "Does +2D6 damage on a roll of a Natural 19 or 20 when using poker cards or any weapon designed for throwing[cite: 7]."
      ]
    },
    {
      "id": "hobbyist_video_games",
      "name": "Video Games",
      "tableCategory": "Hobbyist",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Dark Designs (WB6)",
          "pageNumber": 35
        }
      ],
      "description": "This character's Morphus is likely to resemble the appearance of a character from a video game, be it a hero, villain, or creature[cite: 7]. He wears virtual reality goggles that make everything he sees in the real world appear to be part of a video game[cite: 7]. He also has a wireless video game controller or joystick that he can use to boost and alter his Morphus[cite: 7]!",
      "statModifiers": {
        "iq": {
          "flat": 1
        },
        "ma": {
          "flat": -2
        },
        "ppe": {
          "dice": "-2D6"
        }
      },
      "saveModifiers": {
        "insanity": 2
      },
      "limbDurability": [
        {
          "limbName": "Wireless Controller",
          "quantity": {
            "flat": 1
          },
          "sdc": {
            "flat": 10
          },
          "requiresCalledShot": true,
          "destructionConditionOverrides": {
            "statModifiers": {
              "apm": {
                "flat": -1
              }
            }
          }
        }
      ],
      "recoveryBehaviors": [
        {
          "trigger": "destruction",
          "lockoutHoursDice": "1",
          "note": "If the controller is lost or destroyed, the Nightbane loses 2D4 S.D.C. (or Hit Points if S.D.C. are gone), loses 1 attack per melee, and is -10% on all skills[cite: 7]. To make the controller reappear, he must change back into his Facade and wait one hour before resuming his Morphus[cite: 7]."
        }
      ],
