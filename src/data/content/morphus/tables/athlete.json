    {
      "id": "athlete_streamlined",
      "name": "Streamlined",
      "tableCategory": "Athlete",
      "description": "Built for running, this Nightbane has a lean body with long, powerful limbs. Whether walking, jogging, running, or swimming, he or she seems to glide almost effortlessly across the ground or through the water.",
      "statModifiers": {
        "spd": {
          "dice": "2D4x10+40",
          "isOverride": true
        },
        "pp": {
          "flat": 1
        },
        "ps": {
          "dice": "-1D6"
        },
        "sdc": {
          "percent": -10
        },
        "ar": {
          "flat": -2
        }
      },
      "heightModifier": {
        "flat": 12
      },
      "weightModifier": {
        "percent": -20
      },
      "naturalWeapons": [
        {
          "limbType": "kick",
          "label": "Streamlined Kick",
          "damageFormula": "1D6",
          "isAdditiveToHth": true
        }
      ],
      "customOneOffs": [
        "Even running at maximum speed for hours at a time does NOT fatigue the Nightbane in any way."
      ],
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane® Dark Designs Sourcebook (WB6)",
          "pageNumber": 28
        }
      ]
    },
