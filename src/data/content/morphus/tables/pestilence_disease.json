    {
      "id": "morphus_pestilence_creeping_crud",
      "name": "Creeping Crud",
      "tableCategory": "Pestilence & Disease",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Dark Designs (WB6)",
          "pageNumber": 46
        }
      ],
      "description": "The Morphus is fairly normal looking, though he or she may be a different gender than the Facade, and the body is covered in some sort of crusty or scabby-looking crud that covers half the face, neck, hands, arms and chest. The crusty material can be black, white, grey, red, yellow, green or just about any color, and actually provides a bit of armor-like protection. In the alternative, the crud can be a slime or goo that resembles snot/mucus that seems to either ooze from the body or from open wounds to coat part of the body.",
