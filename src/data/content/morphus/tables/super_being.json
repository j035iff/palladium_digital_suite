          "itemName": "Laser Torch",
          "sdc": 20,
          "regenerationRule": "per_24_hours",
          "effectFormula": "Melee -2 strike, 2D6 damage (counts as one attack); cuts soft materials 15 ft/melee, hard 1 ft/melee; range 6 in (0.15 m); unlimited payload."
        },
        {
          "id": "gadget_mini_map",
          "itemName": "Mini-Map",
          "sdc": 20,
          "regenerationRule": "per_24_hours",
          "effectFormula": "Rough map 50 ft (15.2 m) radius, one story up/down; compass and GPS on visor/wrist. Needs GPS outdoors or floor plans/security tap indoors.",
          "skillGrants": [
            { "targetType": "skill_id", "targetValue": "skill_navigation", "modifierPercent": 30 }
          ]
        },
        {
