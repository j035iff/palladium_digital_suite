        {
          "id": "gadget_rebreather",
          "itemName": "Rebreather Mask",
          "sdc": 20,
          "regenerationRule": "per_24_hours",
          "effectFormula": "Breathe underwater 1D4 hours; same time to recharge oxygen supply."
        },
        {
