    {
      "id": "extraterrestrial_parasitic_alien",
      "name": "Parasitic Alien",
      "tableCategory": "Extraterrestrial",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane Survival Guide (WB5)",
          "pageNumber": 89
        }
      ],
      "description": "The Morphus appears to be a normal human under the control of an icky, slimy, alien parasite. The eyes are blank and lifeless or solid black or solid red, speaks in an even, monotone voice even when excited or shouting, and possesses superhuman strength[cite: 8].",
      "statModifiers": {
        "iq": {
          "flat": -1
        },
        "ma": {
          "flat": -1
        },
        "ps": {
          "dice": "1D6"
        },
        "pe": {
          "flat": 1
        },
        "spd": {
          "percent": -10
        },
        "sdc": {
          "dice": "1D6x10+6"
        },
        "hf": {
          "dice": "1D4"
        }
      },
      "saveModifiers": {
        "mindControl": 4,
        "possession": 4
      },
      "customOneOffs": [
        "The alien parasite is a hideous thing (large leech, worm, insect, crustacean, tentacle thingy, or something else repugnant) attached to the body or under the skin[cite: 8].",
        "Killing or removing the parasite means killing the Nightbane![cite: 8]"
      ]
    },
