      },
      "naturalWeapons": [
        {
          "limbType": "misc_limbs",
          "label": "Palette Shield",
          "damageFormula": "1D4",
          "isAdditiveToHth": false,
          "strikeBonus": -1,
          "parryBonus": 1
        }
      ],
      "customOneOffs": [
        "Can paint images that are startlingly realistic and work like optical illusions for a time. A save vs illusions or a Perception Roll of 14 or better lets observers realize it is a painting."
      ]
    },
    {
      "id": "artisan_bellows_lungs",
      "name": "Bellows Lungs",
      "tableCategory": "Artisan",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Dark Designs (WB6)",
          "pageNumber": 26
        }
      ],
      "description": "The powerful lungs of the Nightbane's Morphus form are actually oversized bellows. Part or all of the flesh of the upper torso is replaced with a dark, leathery material that is visibly ribbed.",
      "statModifiers": {
        "me": {
          "flat": 2
        },
        "pe": {
          "flat": 2
        },
        "sdc": {
          "dice": "3D6"
        },
        "pb": {
          "flat": -2
        }
      },
      "damageAffinities": {
        "heat": 0.5,
        "fire": 0.5
      },
      "skillModifiers": {
        "specificSkillOverrides": [
          {
            "targetType": "skill_id",
            "targetValue": "swimming",
            "modifierPercent": -20
          },
          {
            "targetType": "skill_id",
            "targetValue": "scuba",
            "modifierPercent": -20
          },
          {
            "targetType": "skill_id",
            "targetValue": "prowl",
            "modifierPercent": -10
          }
        ]
      },
      "customOneOffs": [
        "Can hold their breath for a number of minutes equal to their P.E. attribute.",
        "The bellows increase buoyancy, making swimming difficult, and they make a lot more noise than normal breathing."
      ]
    },
    {
      "id": "artisan_drawing_table",
      "name": "Drawing Table",
      "tableCategory": "Artisan",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Dark Designs (WB6)",
          "pageNumber": 26
        }
      ],
      "description": "The front of the torso folds down to reveal a flat, sturdy surface suitable for drawing. The chest cavity contains a variety of drawing implements and tools instead of organs.",
      "statModifiers": {
        "me": {
          "flat": 1
        },
        "ps": {
          "flat": -1
        },
        "pe": {
          "flat": -1
        },
        "pb": {
          "flat": -1
        },
        "spd": {
          "dice": "-1D4"
        },
        "sdc": {
          "dice": "4D6"
        },
        "perception": {
          "flat": 1
        }
      },
      "skillModifiers": {
        "specificSkillOverrides": [
          {
            "targetType": "skill_id",
            "targetValue": "art",
            "modifierPercent": 10
          }
        ]
      },
      "customOneOffs": [
        "Gains the equivalent of the psionic power of Total Recall at no cost, but only for images, not words (includes faces, tattoos, design elements).",
        "Recalled images can be duplicated as a detailed sketch with a successful Art skill roll in 2D4 minutes (twice that for color).",
        "Those skilled in drafting can duplicate building plans just by having seen them or been through the building once."
      ]
    },
    {
