          {
            "targetType": "skill_id",
            "targetValue": "technical_writing",
            "modifierPercent": 10
          }
        ],
        "customSystemRolls": [
          {
            "rollName": "Spontaneous Insight",
            "baseSuccessChance": 5,
            "levelIntervalScaling": {
              "levelInterval": 3,
              "chanceBonus": 3
            }
          }
        ]
      },
      "customOneOffs": [
        "Finished documents either appear on the character's hand, print out, or can be removed from the top of the typewriter.",
        "By taking 1D4 hours to journal, the Nightbane may gain a spontaneous burst of insight about a nagging question (Spontaneous Insight roll).",
        "Nightbane with this feature often seem to be distracted by their own thoughts."
      ]
    },
