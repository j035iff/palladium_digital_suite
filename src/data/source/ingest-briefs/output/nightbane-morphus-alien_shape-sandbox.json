    {
      "id": "alien_shape_on_fire",
      "name": "On Fire",
      "tableCategory": "Alien Shape",
      "gameSystems": [
        "nightbane"
      ],
      "sources": [
        {
          "gameSystem": "nightbane",
          "reference": "Nightbane Survival Guide (WB5)",
          "pageNumber": 73
        }
      ],
      "description": "This is an odd one, perhaps the product of someone who is deathly afraid of fire, or fascinated by it. The Nightbane remains unchanged in appearance except that he is on fire in Morphus form. The fire may only cover his head, neck and shoulders or the entire body. This fire cannot be put out as it does not rely on oxygen (though the Nightbane still needs air to breathe), nor does it produce smoke. Even stranger, the flames catch flammable items on fire only when the Nightbane wishes it (although scorch marks are left everywhere).",
      "statModifiers": {
        "hf": {
          "flat": 2
        }
      },
