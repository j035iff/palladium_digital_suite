{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://megaverse-companion.local/schemas/palladium-magic.schema.json",
  "title": "Palladium magic spell / invocation",
  "description": "Magic invocation catalog row (Nightbane RPG pp. 126–130 pattern; Rifts/Palladium Fantasy variants via optional genre placement). Documents P.P.E. economy, spell level (1–15), range/duration/save (including optional `upkeep` maintenance cycles), `targetPreconditions` for surgical/consent gates (Fleshsculptor), `targetCountFormula` for variable victim counts, offensive `damage`, sensory `reveals`, Horror Factor, ritual flag, `healing` (H.P./S.D.C. restoration and condition `cures`), `resolutionTable` for percentile outcome bands (Teleport, Exorcism), `materialComponents` for physical ritual reagents (Create Golem, Create Mummy), `permanentCosts` for irreversible maximum-pool sacrifices (Familiar Link), `forgedOutputs` for persistent enchanted items (Amulet, Talisman, Scroll), `ritualProfile` for downtime crafting metadata, `spawnedPresence` for constructs and catalog creature summons, `formTransformation` for sheet-replacement metamorphosis, legacy `summonedEntity` (construct alias), `effectProfiles` for modal spells, and optional mechanical automation (`grantedModifiers` / `inflictedModifiers` with `statAdjustments` multipliers and fractions via shared `statAdjustment`, `forceField`, `resistances`, temporary `grantedSkills`, `horrorFactor`). Shared fragments live in `palladium-feature-common.schema.json`. Runtime importers map rows to the universal Feature composer (`metadata.pickBucket`: `magic`). **Genre placement** records setting-specific spell level or P.P.E. overrides when the same invocation appears across Megaversal books.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "description",
    "gameSystems",
    "sources",
    "school",
    "spellLevel"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "minLength": 1,
      "description": "Canonical catalog id: `magic_<school>_<spell_slug>` where `<school>` matches the content file basename (e.g. `magic_wizard_blinding_flash` in `content/magic/wizard.json`)."
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "descriptionMorphus": { "type": "string", "minLength": 1 },
    "gameSystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "school": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "minLength": 1,
      "description": "Magic school slug — must match the content file basename (`wizard.json` → `wizard`) and the `magic_<school>_` id prefix."
    },
    "spellLevel": {
      "type": "integer",
      "minimum": 1,
      "maximum": 15,
      "description": "Invocation level (Nightbane core book lists levels 1–15, pp. 127–130)."
    },
    "magicKind": {
      "type": "string",
      "enum": [
        "invocation",
        "ritual",
        "ward",
        "circle",
        "enchantment",
        "summoning",
        "necromancy",
        "fleshsculpting",
        "other"
      ],
      "description": "Primary magic tradition or delivery form. Ritual invocations use base spell strength 16 (p. 127). `fleshsculpting` — mystical surgery and biological reshaping (Through the Glass Darkly)."
    },
    "isRitual": {
      "type": "boolean",
      "description": "True when the spell requires ritual casting (e.g. Ritual: Call Creature of Light)."
    },
    "spellStrengthBase": {
      "type": "integer",
      "enum": [12, 16],
      "description": "Base magic strength/attack: 12 for invocations, 16 for rituals (Nightbane p. 127)."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "genrePlacements": {
      "type": "array",
      "minItems": 1,
      "description": "Per-genre spell level and/or P.P.E. overrides when the same invocation differs by setting.",
      "items": { "$ref": "#/$defs/magicGenrePlacement" }
    },
    "ppe": { "$ref": "#/$defs/magicPpeEconomy" },
    "limitations": { "$ref": "#/$defs/magicLimitations" },
    "targetPreconditions": {
      "description": "Structured target state gates before cast (e.g. Fleshsculptor: placid or willing). Distinct from touch/LOS flags in `limitations`.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/castingTargetPreconditions"
    },
    "ranges": {
      "type": "array",
      "items": { "$ref": "#/$defs/magicRangeEntry" }
    },
    "range": { "$ref": "#/$defs/proseBlock" },
    "duration": { "$ref": "#/$defs/magicDuration" },
    "areaOfEffect": { "$ref": "#/$defs/proseBlock" },
    "damage": {
      "oneOf": [
        { "$ref": "#/$defs/magicDamage" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "healing": { "$ref": "#/$defs/magicHealing" },
    "save": {
      "oneOf": [
        { "$ref": "#/$defs/magicSaveEntry" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/magicSaveEntry" }
        },
        { "type": "string", "minLength": 1 }
      ]
    },
    "targetCountFormula": {
      "type": "string",
      "minLength": 1,
      "description": "Dice or scaling formula determining how many targets or victims the spell affects (e.g. `1D6 per level of experience` for Turn Dead or Sleep)."
    },
    "horrorFactor": {
      "type": "integer",
      "minimum": 1,
      "description": "Horror Factor generated by the spell (e.g. Thunderclap H.F. 8, p. 130)."
    },
    "reveals": {
      "type": "array",
      "description": "Information categories disclosed by sensory spells (e.g. See Aura, Sense Magic).",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "alarmTrigger": {
      "description": "Dormant ward that fires when environmental conditions are met (e.g. Watching Enchantment). Distinct from active `reveals` scanning.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/alarmTrigger"
    },
    "combatBonuses": { "$ref": "#/$defs/passiveModifiers" },
    "grantedModifiers": { "$ref": "#/$defs/magicGrantedModifiers" },
    "inflictedModifiers": { "$ref": "#/$defs/magicInflictedModifiers" },
    "resolutionTable": {
      "description": "Percentile or dice outcome bands mapped to mechanical effects (e.g. Teleport arrival accuracy, Exorcism sub-outcomes).",
      "$ref": "#/$defs/magicResolutionTable"
    },
    "materialComponents": {
      "description": "Physical inventory reagents required to cast or complete the ritual (distinct from `ppe` and `permanentCosts`).",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/materialRequirements"
    },
    "permanentCosts": {
      "type": "array",
      "description": "Irreversible maximum-pool or attribute sacrifices (distinct from `ppe` activation cost). Each entry's `trigger` controls whether the drain fires on cast or only on success.",
      "minItems": 1,
      "items": {
        "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/permanentCostEntry"
      }
    },
    "forgedOutputs": {
      "type": "array",
      "description": "Persistent equippable items created on success (amulets, talismans, scrolls). Distinct from `spawnedPresence` field entities.",
      "minItems": 1,
      "items": {
        "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/forgedItemOutput"
      }
    },
    "ritualProfile": {
      "description": "Downtime ritual wrapper for high-level crafting spells (duration, workspace, assistants).",
      "$ref": "#/$defs/magicRitualProfile"
    },
    "spawnedPresence": {
      "description": "Construct or catalog creature spawned by the spell (`kind`: `construct` | `creature`). Prefer over legacy `summonedEntity`.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresence"
    },
    "formTransformation": {
      "description": "Temporary sheet replacement while the spell is active (e.g. Metamorphosis: Animal, Mist). Distinct from `grantedModifiers` overlay buffs.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/formTransformation"
    },
    "summonedEntity": {
      "description": "Deprecated construct alias — treat as `spawnedPresence` with `kind: construct`. Retained for backward compatibility (e.g. Magic Net).",
      "$ref": "#/$defs/magicSummonedEntity"
    },
    "effectProfiles": {
      "type": "array",
      "description": "Selectable sub-effects for modal spells where the caster chooses exactly one distinct mechanical outcome at cast time (e.g. Charismatic Aura).",
      "minItems": 1,
      "items": { "$ref": "#/$defs/magicEffectProfile" }
    },
    "prerequisites": {
      "type": "array",
      "items": { "$ref": "#/$defs/magicPrerequisite" }
    },
    "incompatibleSpellIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
      "uniqueItems": true
    },
    "notes": { "type": "string", "minLength": 1 },
    "formRequirement": {
      "type": "string",
      "enum": ["morphus", "facade", "either"]
    },
    "activation": { "$ref": "#/$defs/magicActivation" },
    "durationType": {
      "type": "string",
      "enum": ["instant", "melee", "narrative", "permanent", "concentration"]
    },
    "pumpable": { "$ref": "#/$defs/pumpRule" }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameSystem", "reference", "pageNumber"],
      "properties": {
        "gameSystem": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "minLength": 1
        },
        "reference": { "type": "string", "minLength": 1 },
        "pageNumber": { "type": "integer", "minimum": 1 }
      }
    },
    "proseBlock": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "magicGenrePlacement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["genreId"],
      "properties": {
        "genreId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1
        },
        "spellLevel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 15
        },
        "ppe": { "$ref": "#/$defs/magicPpeEconomy" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "magicPpeEconomy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "baseActivation": {
          "description": "P.P.E. spent to cast (fixed integer, dice/prose, or structured relative cost).",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "perLevel": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "perMinute": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "perTarget": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "notes": { "type": "string", "minLength": 1 },
        "dynamicCosts": {
          "type": "array",
          "items": { "$ref": "#/$defs/magicDynamicCostEntry" }
        },
        "enhancement": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "costPerStep": { "type": "integer", "minimum": 0 },
            "stepDefinition": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "magicDynamicCostEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "costFormula"],
      "properties": {
        "trigger": { "type": "string", "minLength": 1 },
        "costFormula": { "type": "string", "minLength": 1 }
      }
    },
    "magicLimitations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "selfOnly": { "type": "boolean" },
        "cannotAffectSelf": { "type": "boolean" },
        "lineOfSightRequired": { "type": "boolean" },
        "lineOfVisionRequired": { "type": "boolean" },
        "touchRequired": { "type": "boolean" },
        "concentrationRequired": { "type": "boolean" },
        "cancellableAtWill": { "type": "boolean" },
        "cannotUseWhile": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "otherLimitations": { "type": "string", "minLength": 1 }
      }
    },
    "magicRangeEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "touch",
            "distance",
            "self",
            "radius",
            "line_of_sight",
            "line_of_vision",
            "area",
            "special"
          ]
        },
        "distanceValue": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "distanceUnit": {
          "type": "string",
          "enum": ["foot", "feet", "mile", "miles", "meter", "meters"]
        },
        "distancePerLevel": { "type": "number", "minimum": 0 },
        "radiusValue": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "magicDuration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "instant",
            "melee_round",
            "minute",
            "hour",
            "day",
            "week",
            "month",
            "year",
            "permanent",
            "until_condition",
            "special"
          ]
        },
        "durationValue": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "perLevel": { "type": "string", "minLength": 1 },
        "upkeep": {
          "description": "Optional maintenance cycle — pay `cost` each `interval` to reset or sustain this duration (e.g. Replace Limb P.P.E. recharge).",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/effectUpkeep"
        }
      }
    },
    "magicSaveEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "saveKind": {
          "type": "string",
          "enum": [
            "standard",
            "magic",
            "horror_factor",
            "dodge",
            "psionic",
            "none",
            "conditional",
            "special"
          ]
        },
        "targetNumber": { "type": "integer", "minimum": 1 },
        "bonus": { "type": "string", "minLength": 1 },
        "effectsOnFailedSave": { "type": "string", "minLength": 1 },
        "effectsOnSuccessfulSave": { "type": "string", "minLength": 1 }
      }
    },
    "magicDamage": {
      "type": "object",
      "additionalProperties": true,
      "description": "Direct damage on cast or sustained harm. Use `formula` for a single tick; use `progression` for escalating tracks (Fatal Growth geometric doubling).",
      "properties": {
        "formula": {
          "type": "string",
          "minLength": 1,
          "description": "Single-tick damage dice or prose. Omit when `progression` supplies `baseFormula`."
        },
        "progression": {
          "description": "Escalating damage cadence resolved each tick by combat trackers (e.g. Fatal Growth doubles every melee round).",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/damageProgression"
        },
        "primaryTargetDamage": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "magicHealing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hpFormula": { "type": "string", "minLength": 1 },
        "sdcFormula": { "type": "string", "minLength": 1 },
        "cures": {
          "type": "array",
          "description": "Negative status conditions, toxins, or debuffs instantly removed by the spell (e.g. poison, toxin, paralysis).",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "passiveModifiers": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "magicInflictedCombatModifiers": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "strike": { "type": "integer" },
        "parry": { "type": "integer" },
        "dodge": { "type": "integer" },
        "speedMultiplier": { "type": "number" },
        "attacksPerMelee": { "type": "integer" }
      }
    },
    "magicInflictedModifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "statusEffects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "combatModifiers": {
          "$ref": "#/$defs/magicInflictedCombatModifiers"
        },
        "statAdjustments": {
          "description": "Temporary attribute penalties or fractional debuffs (e.g. halve P.B., halve S.D.C., Age halves physical attributes). Integer shorthand or shared `statAdjustment` objects.",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/statAdjustmentMap"
        },
        "globalSkillModifier": {
          "description": "Global percentile penalty applied to all of the victim's existing skills (e.g. Sickness −40%, Befuddle −25%).",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/globalSkillModifier"
        },
        "personalityOverride": {
          "description": "Permanent or long-term alignment and insanity transformations (e.g. Someone Makes Them).",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/personalityOverride"
        }
      }
    },
    "magicGrantedCombatModifiers": {
      "type": "object",
      "additionalProperties": true,
      "description": "Flat integer strike/parry/dodge/save bonuses plus optional weapon damage buffs granted to the target (e.g. Enchant Weapon doubles damage vs supernatural beings).",
      "properties": {
        "strike": { "type": "integer" },
        "parry": { "type": "integer" },
        "dodge": { "type": "integer" },
        "initiative": { "type": "integer" },
        "saveMagic": { "type": "integer" },
        "saveHorrorFactor": { "type": "integer" },
        "damageBonus": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Flat additive weapon damage or Palladium dice notation (e.g. `2`, `1D6`) applied while the enchantment persists."
        },
        "damageMultiplier": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Damage multiplier applied to weapon attacks (e.g. `2` for double damage)."
        },
        "damageCondition": {
          "type": "string",
          "minLength": 1,
          "description": "Target or circumstance required for `damageBonus` / `damageMultiplier` to apply (e.g. `against supernatural beings`)."
        }
      }
    },
    "magicGrantedStatModifiers": {
      "description": "Temporary attribute buffs granted while the spell is active (e.g. Superhuman Strength P.S., Superhuman Speed Spd. override). Integer shorthand or shared `statAdjustment` (multiplier, fraction, formula, override).",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/statAdjustmentMap"
    },
    "magicRitualProfile": {
      "type": "object",
      "additionalProperties": false,
      "description": "High-level ritual and crafting metadata grouped for downtime workflows.",
      "properties": {
        "craftingDuration": { "$ref": "#/$defs/magicDuration" },
        "workspace": { "$ref": "#/$defs/proseBlock" },
        "materialComponents": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/materialRequirements"
        },
        "assistantsRequired": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of assistants required during the ritual period."
        },
        "failureHandling": {
          "type": "string",
          "enum": ["lose_materials_only", "lose_materials_and_ppe", "lose_all", "narrative"],
          "description": "What is lost when the ritual fails after materials are committed."
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "magicGrantedSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "basePercentage"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Temporary skill label (e.g. Climbing, Prowl)."
        },
        "basePercentage": {
          "type": "string",
          "minLength": 1,
          "description": "Granted skill proficiency (e.g. `98%`, `85/75%` for split surface ratings)."
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Conditional proficiency rules (e.g. `90% undetectable if unmoving, 70% if moving`)."
        }
      }
    },
    "magicGrantedForceField": {
      "type": "object",
      "additionalProperties": false,
      "description": "Temporary, ablative magical health pool that depletes before physical S.D.C. (e.g. Armor of Ithan, Magic Armor).",
      "properties": {
        "sdcFormula": {
          "type": "string",
          "minLength": 1,
          "description": "Magical S.D.C. pool formula (e.g. `10 per level of experience`)."
        }
      }
    },
    "magicGrantedMovement": {
      "type": "object",
      "description": "Temporary movement capabilities granted while the spell is active (e.g. flightSpeed, hover, horizontalSpeed).",
      "additionalProperties": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          { "type": "integer" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      },
      "properties": {
        "flightSpeed": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer" }
          ]
        },
        "hover": { "type": "boolean" }
      }
    },
    "magicGrantedModifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "enum": ["self", "touch", "line_of_sight", "area", "other"]
        },
        "immunities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "resistances": {
          "type": "array",
          "description": "Damage types or effects where the target takes half damage or has partial resistance (e.g. fire, cold).",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "forceField": {
          "description": "Temporary magical armor / ablative S.D.C. granted while the spell is active.",
          "$ref": "#/$defs/magicGrantedForceField"
        },
        "movement": {
          "description": "Temporary movement capabilities granted while the spell is active.",
          "$ref": "#/$defs/magicGrantedMovement"
        },
        "combatModifiers": {
          "$ref": "#/$defs/magicGrantedCombatModifiers"
        },
        "statModifiers": {
          "$ref": "#/$defs/magicGrantedStatModifiers"
        },
        "grantedSkills": {
          "type": "array",
          "description": "Temporary percentile skills granted while the spell is active (e.g. Climb, Concealment).",
          "minItems": 1,
          "items": { "$ref": "#/$defs/magicGrantedSkill" }
        },
        "globalSkillModifier": {
          "description": "Global percentile bonus applied to all of the recipient's existing skills while the effect is active.",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/globalSkillModifier"
        },
        "damageReflection": {
          "description": "Damage retribution — qualifying incoming harm is mirrored back to the attacker (e.g. Ritual: An Eye for an Eye).",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/damageReflection"
        }
      }
    },
    "magicActivation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cost": { "$ref": "#/$defs/activationCost" },
        "range": { "type": "string", "minLength": 1 },
        "duration": { "type": "string", "minLength": 1 },
        "save": { "type": "string", "minLength": 1 }
      }
    },
    "activationCost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ppe", "isp", "action", "other", "none"]
        },
        "value": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "pumpRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capPerLevel", "energyPerDice", "diceSides"],
      "properties": {
        "capPerLevel": { "type": "integer", "minimum": 0 },
        "energyPerDice": { "type": "integer", "minimum": 1 },
        "diceSides": { "type": "integer", "minimum": 2 }
      }
    },
    "magicPrerequisite": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "spell",
            "attribute_minimum",
            "level_minimum",
            "other_spell_any_of",
            "occ",
            "other"
          ]
        },
        "spellId": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "spellIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "uniqueItems": true
        },
        "attribute": {
          "type": "string",
          "enum": ["iq", "me", "ma", "ps", "pp", "pe", "pb", "spd"]
        },
        "minimum": { "type": "integer", "minimum": 1 },
        "level": { "type": "integer", "minimum": 1, "maximum": 15 },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "magicSummonedEntity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Legacy construct shape — equivalent to `spawnedPresence` with `kind: construct` and optional `derivedHealth` only.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Construct label (e.g. Magic Net, Energy Field)."
        },
        "derivedHealth": {
          "type": "string",
          "minLength": 1,
          "description": "Construct S.D.C. pool formula (e.g. `60 S.D.C.`, `20 S.D.C. per level of experience`)."
        }
      }
    },
    "magicResolutionTableEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect"],
      "description": "Magic resolution table row — extends common `resolutionTableEntry` with optional modifier automation and nested follow-up tables.",
      "properties": {
        "percentile": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/percentileRange"
        },
        "rollRange": {
          "type": "string",
          "minLength": 1,
          "description": "Authoring shorthand for an outcome band (e.g. `01-20`, `77-00`)."
        },
        "label": { "type": "string", "minLength": 1 },
        "effect": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "grantedModifiers": { "$ref": "#/$defs/magicGrantedModifiers" },
        "inflictedModifiers": { "$ref": "#/$defs/magicInflictedModifiers" },
        "followUpTable": { "$ref": "#/$defs/magicResolutionTable" }
      },
      "oneOf": [
        { "required": ["percentile"] },
        { "required": ["rollRange"] }
      ]
    },
    "magicResolutionTable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries"],
      "properties": {
        "rollKind": {
          "type": "string",
          "enum": ["d100", "d20", "d6", "d4", "other"]
        },
        "label": { "type": "string", "minLength": 1 },
        "resolutionTrigger": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/resolutionTrigger"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/magicResolutionTableEntry" }
        }
      }
    },
    "magicEffectProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Modal option label shown at cast time."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Mechanical outcome prose for this selected mode."
        },
        "ppeOverride": {
          "description": "Modal P.P.E. economy for this profile — replaces root `ppe` when the caster selects this option at cast time (e.g. Amulet Charm 290 vs See the Invisible 500).",
          "$ref": "#/$defs/magicPpeEconomy"
        },
        "targetPreconditions": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/castingTargetPreconditions"
        },
        "save": {
          "oneOf": [
            { "$ref": "#/$defs/magicSaveEntry" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/magicSaveEntry" }
            },
            { "type": "string", "minLength": 1 }
          ]
        },
        "horrorFactor": {
          "type": "integer",
          "minimum": 1
        },
        "targetCountFormula": {
          "type": "string",
          "minLength": 1
        },
        "duration": {
          "description": "Modal duration for this profile when it differs from root `duration` (e.g. Wards alarm lasts 10 minutes).",
          "$ref": "#/$defs/magicDuration"
        },
        "damage": {
          "oneOf": [
            { "$ref": "#/$defs/magicDamage" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Modal damage for this profile (e.g. Wards fire bolt 6D6)."
        },
        "inflictedModifiers": { "$ref": "#/$defs/magicInflictedModifiers" },
        "grantedModifiers": { "$ref": "#/$defs/magicGrantedModifiers" },
        "resolutionTable": { "$ref": "#/$defs/magicResolutionTable" },
        "spawnedPresence": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresence"
        },
        "formTransformation": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/formTransformation"
        },
        "materialComponents": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/materialRequirements"
        },
        "forgedOutputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/forgedItemOutput"
          }
        }
      }
    }
  }
}
