{
  "$schema": "../palladium-magic.schema.json",
  "id": "magic_wizard_teleport",
  "name": "Teleport",
  "description": "Instantly transports the caster to a known destination. Arrival accuracy is resolved on a percentile table.",
  "gameSystems": [
    "nightbane"
  ],
  "sources": [
    {
      "gameSystem": "nightbane",
      "reference": "Nightbane RPG (example)",
      "pageNumber": 129
    }
  ],
  "school": "wizard",
  "spellLevel": 5,
  "magicKind": "invocation",
  "spellStrengthBase": 12,
  "ppe": {
    "baseActivation": 50
  },
  "range": {
    "summary": "Self or one touched person."
  },
  "duration": {
    "summary": "Instant.",
    "kind": "instant"
  },
  "resolutionTable": {
    "rollKind": "d100",
    "label": "Teleport arrival accuracy",
    "resolutionTrigger": {
      "when": "on_cast",
      "rollKind": "d100"
    },
    "entries": [
      {
        "percentile": {
          "min": 1,
          "max": 20
        },
        "label": "On target",
        "effect": "Arrive at the intended destination."
      },
      {
        "percentile": {
          "min": 21,
          "max": 80
        },
        "label": "Off course",
        "effect": "Arrive 2D6×100 feet (30.5 m) from the intended destination."
      },
      {
        "percentile": {
          "min": 81,
          "max": 100
        },
        "label": "Disastrous",
        "effect": "Arrive 4D6 miles from the intended destination in a random direction.",
        "inflictedModifiers": {
          "statusEffects": [
            "disoriented"
          ]
        }
      }
    ]
  },
  "durationType": "instant"
}
