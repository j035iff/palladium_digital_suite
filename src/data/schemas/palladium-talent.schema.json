{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://megaverse-companion.local/schemas/palladium-talent.schema.json",
  "title": "Palladium Nightbane talent",
  "description": "Nightbane **Talent** catalog row (Dark Designs / Survival Guide pattern).\n\n**Engine contract (see `scripts/talent-engine-contract.mjs`):**\n- **Tier 1 (chargen)** — `talentTier`, `ppe`, `limitations`, `prerequisites`, `sources`, descriptions. Consumed by creation picker, gates, PPE display.\n- **Tier 2 (play)** — optional blocks (`powerModes`, `combatMechanics`, `vampiricResourceRecovery`, …). For FeatureCard / combat when wired; not required for chargen ingest Pass A.\n\nRuntime importers map rows to the universal **Feature** composer (`metadata.pickBucket`: `talent`).",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name", "description", "gameSystems", "sources"],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "minLength": 1
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "descriptionMorphus": { "type": "string", "minLength": 1 },
    "gameSystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "talentTier": {
      "type": "string",
      "enum": ["common", "elite", "uncommon", "rare", "very_rare"],
      "description": "Dark Designs rarity band (common / elite morphus-table talents, etc.)."
    },
    "tier": {
      "type": "string",
      "enum": ["common", "uncommon", "rare", "very_rare", "elite"],
      "description": "Alias for talentTier in slim authoring rows."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "ppe": { "$ref": "#/$defs/talentPpeEconomy" },
    "limitations": { "$ref": "#/$defs/talentLimitations" },
    "ranges": {
      "type": "array",
      "items": { "$ref": "#/$defs/talentRangeEntry" }
    },
    "range": { "$ref": "#/$defs/proseBlock" },
    "duration": { "$ref": "#/$defs/talentDuration" },
    "areaOfEffect": { "$ref": "#/$defs/proseBlock" },
    "damage": {
      "oneOf": [
        { "$ref": "#/$defs/talentDamage" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "save": {
      "oneOf": [
        { "$ref": "#/$defs/talentSaveEntry" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/talentSaveEntry" }
        },
        { "type": "string", "minLength": 1 }
      ]
    },
    "combat": { "type": "object", "additionalProperties": true },
    "resolutionTable": {
      "description": "Percentile or dice outcome bands for modal or conditional talents.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/resolutionTable"
    },
    "permanentCosts": {
      "type": "array",
      "description": "Irreversible maximum-pool sacrifices applied once when the talent is acquired or first activated (distinct from `ppe.permanentBurnToAcquire`).",
      "minItems": 1,
      "items": {
        "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/permanentCostEntry"
      }
    },
    "spawnedPresence": {
      "description": "Construct or catalog creature spawned by the talent.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresence"
    },
    "formTransformation": {
      "description": "Temporary sheet replacement while the talent is active.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/formTransformation"
    },
    "materialComponents": {
      "description": "Physical reagents required to activate or acquire the talent.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/materialRequirements"
    },
    "forgedOutputs": {
      "type": "array",
      "description": "Persistent items created when the talent is used (rare crafting talents).",
      "minItems": 1,
      "items": {
        "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/forgedItemOutput"
      }
    },
    "prerequisites": {
      "description": "Morphus-table gates or structured chargen prerequisites.",
      "oneOf": [
        { "$ref": "#/$defs/morphusTablePrerequisites" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/talentPrerequisite" }
        }
      ]
    },
    "incompatibleTalentIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
      "uniqueItems": true
    },
    "notes": { "type": "string", "minLength": 1 },
    "modifiers": { "$ref": "#/$defs/passiveModifiers" },
    "formRequirement": {
      "type": "string",
      "enum": ["morphus", "facade", "either"]
    },
    "activation": { "$ref": "#/$defs/talentActivation" },
    "durationType": {
      "type": "string",
      "enum": ["instant", "melee", "narrative"]
    },
    "pumpable": { "$ref": "#/$defs/pumpRule" },
    "powerModes": { "$ref": "#/$defs/talentPowerModes" },
    "combatMechanics": { "$ref": "#/$defs/talentCombatMechanics" },
    "vampiricResourceRecovery": { "$ref": "#/$defs/talentVampiricResourceRecovery" },
    "activationTime": { "$ref": "#/$defs/tier2PlayBlock" },
    "rangeMechanics": { "$ref": "#/$defs/tier2PlayBlock" },
    "createdObjects": { "$ref": "#/$defs/tier2PlayBlock" },
    "rangeAndArea": { "$ref": "#/$defs/tier2PlayBlock" },
    "penaltiesOnAffectedCharacters": { "$ref": "#/$defs/tier2PlayBlock" },
    "statusAlterations": { "$ref": "#/$defs/tier2PlayBlock" },
    "physicalCombatStatModifiers": { "$ref": "#/$defs/tier2PlayBlock" },
    "savingThrows": { "$ref": "#/$defs/tier2PlayBlock" },
    "physicalBonusesPenalties": { "$ref": "#/$defs/tier2PlayBlock" },
    "attacksAndDamage": { "$ref": "#/$defs/tier2PlayBlock" },
    "damageModifiersNote": { "$ref": "#/$defs/tier2PlayBlock" },
    "offensiveDamage": { "$ref": "#/$defs/tier2PlayBlock" },
    "mobilityBlocks": { "$ref": "#/$defs/tier2PlayBlock" },
    "statusEffects": { "$ref": "#/$defs/tier2PlayBlock" },
    "temporaryAbilitiesGranted": { "$ref": "#/$defs/tier2PlayBlock" },
    "structureReinforcements": { "$ref": "#/$defs/tier2PlayBlock" },
    "grantedSkills": { "$ref": "#/$defs/tier2PlayBlock" },
    "passengerLimits": { "$ref": "#/$defs/tier2PlayBlock" },
    "recoveryStateUntilThreshold": { "$ref": "#/$defs/tier2PlayBlock" },
    "environmentalConstructs": { "$ref": "#/$defs/tier2PlayBlock" },
    "opponentConditionalModifiers": { "$ref": "#/$defs/tier2PlayBlock" },
    "retroactiveWindow": { "$ref": "#/$defs/tier2PlayBlock" },
    "jumpDistanceScaling": { "$ref": "#/$defs/tier2PlayBlock" },
    "passengerCompanionCapacity": { "$ref": "#/$defs/tier2PlayBlock" },
    "activationRequirements": { "$ref": "#/$defs/tier2PlayBlock" },
    "activationDamage": { "$ref": "#/$defs/tier2PlayBlock" },
    "alignmentGatedEffects": { "$ref": "#/$defs/tier2PlayBlock" },
    "bonusDamageVsNightlandsDenizens": { "$ref": "#/$defs/tier2PlayBlock" },
    "temporaryResourcePools": { "$ref": "#/$defs/tier2PlayBlock" },
    "environmentalAmplifiers": { "$ref": "#/$defs/tier2PlayBlock" },
    "reflectionMechanics": { "$ref": "#/$defs/tier2PlayBlock" },
    "attributeCost": { "$ref": "#/$defs/tier2PlayBlock" },
    "bonusesOnAlliedTargets": { "$ref": "#/$defs/tier2PlayBlock" },
    "attributeBurn": { "$ref": "#/$defs/tier2PlayBlock" },
    "comaHitPointBuffer": { "$ref": "#/$defs/tier2PlayBlock" },
    "skillsGranted": { "$ref": "#/$defs/tier2PlayBlock" },
    "penaltiesOnCaster": { "$ref": "#/$defs/tier2PlayBlock" },
    "healing": { "$ref": "#/$defs/tier2PlayBlock" },
    "objectsAffected": { "$ref": "#/$defs/tier2PlayBlock" },
    "swarmMechanics": { "$ref": "#/$defs/tier2PlayBlock" },
    "holdsAndEscapes": { "$ref": "#/$defs/tier2PlayBlock" },
    "damageTakenModifiers": { "$ref": "#/$defs/tier2PlayBlock" }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameSystem", "reference", "pageNumber"],
      "properties": {
        "gameSystem": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "minLength": 1
        },
        "reference": { "type": "string", "minLength": 1 },
        "pageNumber": { "type": "integer", "minimum": 1 }
      }
    },
    "proseBlock": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "talentPpeEconomy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "permanentBurnToAcquire": {
          "description": "P.P.E. permanently spent when the talent is first acquired.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "baseActivation": {
          "description": "P.P.E. spent each time the talent is activated (fixed integer, prose, or structured relative cost).",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "notes": { "type": "string", "minLength": 1 },
        "enhancement": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "costPerStep": { "type": "integer", "minimum": 0 },
            "stepDefinition": { "type": "string", "minLength": 1 }
          }
        },
        "activationTiers": {
          "type": "array",
          "description": "Tiered activation P.P.E. brackets (e.g. by effect scale).",
          "minItems": 1,
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "tier2PlayBlock": {
      "description": "Tier 2 play-mechanics fragment. Structured object when possible; prose string or array of sub-blocks also valid during ingest.",
      "oneOf": [
        { "type": "object", "additionalProperties": true },
        { "type": "array", "minItems": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "talentPowerModeEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["modeName"],
      "properties": {
        "modeName": { "type": "string", "minLength": 1 },
        "effectsDescription": { "type": "string", "minLength": 1 }
      }
    },
    "talentPowerModes": {
      "type": "array",
      "description": "Modal talent — pick one boost or effect mode at activation.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/talentPowerModeEntry" }
    },
    "talentCombatMechanics": {
      "type": "object",
      "additionalProperties": true,
      "description": "Saves, strike bonuses, and combat consequences for play resolution.",
      "properties": {
        "savingThrow": { "type": "object", "additionalProperties": true },
        "rangeSummary": { "type": "string", "minLength": 1 }
      }
    },
    "talentVampiricResourceRecovery": {
      "type": "object",
      "additionalProperties": true,
      "description": "P.P.E./H.P. recovery triggered by kills or drains.",
      "properties": {
        "triggerKind": { "type": "string", "minLength": 1 },
        "recoveryFractionOrPercent": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "resourceType": { "type": "string", "enum": ["ppe", "isp", "hit_points", "sdc", "other"] }
      }
    },
    "talentFormRestriction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["form"],
      "properties": {
        "form": {
          "type": "string",
          "enum": ["morphus_only", "facade_only", "either_form"]
        },
        "effectiveness": {
          "type": "string",
          "description": "When P.P.E. enhancements or scaled effects differ at this scope.",
          "enum": ["full", "base_only", "reduced"]
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "talentFormUsageByTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "self": { "$ref": "#/$defs/talentFormRestriction" },
        "others": { "$ref": "#/$defs/talentFormRestriction" },
        "willing": { "$ref": "#/$defs/talentFormRestriction" }
      },
      "minProperties": 1
    },
    "talentFormUsagePhases": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activation": { "$ref": "#/$defs/talentFormRestriction" },
        "ongoingUse": { "$ref": "#/$defs/talentFormRestriction" }
      },
      "minProperties": 1
    },
    "talentFormUsage": {
      "type": "object",
      "additionalProperties": false,
      "description": "Explicit Facade/Morphus rules when restrictions differ by who is affected or when during use.",
      "properties": {
        "byTarget": { "$ref": "#/$defs/talentFormUsageByTarget" },
        "phases": { "$ref": "#/$defs/talentFormUsagePhases" }
      },
      "anyOf": [
        { "required": ["byTarget"] },
        { "required": ["phases"] }
      ]
    },
    "talentLimitations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "usableInNightbaneForm": {
          "type": "string",
          "description": "Simple form rule when uniform for all uses. **Default: morphus_only.** Use `varies_by_scope` with `formUsage` when rules differ by target or phase.",
          "enum": [
            "morphus_only",
            "facade_only",
            "either_form",
            "varies_by_scope",
            "both_forms_note_special"
          ],
          "default": "morphus_only"
        },
        "formUsage": {
          "description": "Structured Facade/Morphus restrictions by target (self, others, willing) or phase (activation, ongoing use). Prefer over form prose in `otherLimitations`.",
          "$ref": "#/$defs/talentFormUsage"
        },
        "minimumCharacterLevelToAcquire": {
          "type": "integer",
          "minimum": 1,
          "maximum": 15
        },
        "cannotAffect": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "otherLimitations": { "type": "string", "minLength": 1 },
        "morphusTablePrerequisites": {
          "type": "array",
          "description": "Prose Morphus trait gates when structured `prerequisites.morphusTableIds` is unavailable. Prefer structured ids for chargen auto-gating.",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "talentRangeEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "touch",
            "distance",
            "self",
            "radius",
            "line_of_sight",
            "special"
          ]
        },
        "distanceValue": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "distanceUnit": {
          "type": "string",
          "enum": ["foot", "feet", "mile", "miles", "meter", "meters"]
        },
        "distancePerLevel": { "type": "number", "minimum": 0 }
      }
    },
    "talentDuration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["instant", "melee_round", "minute", "hour", "special"]
        },
        "durationValue": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "value": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "talentSaveEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "saveKind": { "type": "string", "minLength": 1 },
        "targetNumber": { "type": "integer", "minimum": 1 },
        "effectsOnFailedSave": { "type": "string", "minLength": 1 }
      }
    },
    "talentDamage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "primaryTargetDamage": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "morphusTablePrerequisites": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "morphusTableIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "passiveModifiers": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "talentActivation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cost": { "$ref": "#/$defs/activationCost" },
        "range": { "type": "string", "minLength": 1 },
        "duration": { "type": "string", "minLength": 1 },
        "save": { "type": "string", "minLength": 1 }
      }
    },
    "activationCost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ppe", "isp", "action", "other", "none"]
        },
        "value": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "pumpRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capPerLevel", "energyPerDice", "diceSides"],
      "properties": {
        "capPerLevel": { "type": "integer", "minimum": 0 },
        "energyPerDice": { "type": "integer", "minimum": 1 },
        "diceSides": { "type": "integer", "minimum": 2 }
      }
    },
    "talentPrerequisite": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "talent",
            "attribute_minimum",
            "level_minimum",
            "other_talent_any_of"
          ]
        },
        "talentId": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "talentIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "uniqueItems": true
        },
        "attribute": {
          "type": "string",
          "enum": ["iq", "me", "ma", "ps", "pp", "pe", "pb", "spd"]
        },
        "minimum": { "type": "integer", "minimum": 1 },
        "level": { "type": "integer", "minimum": 1, "maximum": 15 },
        "label": { "type": "string", "minLength": 1 }
      }
    }
  }
}
