{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://megaverse-companion.local/schemas/palladium-occ.schema.json",
  "title": "Palladium RPG O.C.C.",
  "description": "Occupational Character Class — composition-first catalog row: identity, prerequisites, core/elective skills, combat paths, static bonuses, supernatural engines (P.P.E. / I.S.P. / custom), gear, and finances. Optional blocks are pluggable modules; omit what the book does not use.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description",
    "gameSystems",
    "sources",
    "occType",
    "tags",
    "occSkillsCore",
    "occRelatedSkills",
    "secondarySkills",
    "wpRules",
    "handToHandRules"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Pointer to this schema for editor validation."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Stable machine id (e.g. occ_ex_government_agent, occ_pab_psychic_agent)."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "genresAvailable": {
      "type": "array",
      "description": "Optional genre gate for campaign filtering (e.g. nightbane). When omitted, derived from gameSystems.",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "gameSystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sources": {
      "$ref": "#/$defs/sources"
    },
    "occType": {
      "type": "string",
      "minLength": 1,
      "description": "Book grouping slug (e.g. man_of_arms, law_enforcement, magic_user, psychic, scholar_civilian). Expandable — not a closed enum."
    },
    "tags": {
      "type": "array",
      "description": "Background tags for race vitals conditionals and filters (e.g. military, police, detective).",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "attributeRequirements": {
      "$ref": "#/$defs/attributeRequirements"
    },
    "alignmentRestrictions": {
      "$ref": "#/$defs/alignmentRestrictions"
    },
    "raceRestrictions": {
      "$ref": "#/$defs/raceRestrictions"
    },
    "specializations": {
      "type": "array",
      "description": "Optional sub-class branches (e.g. Team Epsilon vs Public Special Forces, ADA Spy vs Assassin). When the player selects one, engines merge override modules into the baseline row (see resolveEffectivePalladiumOcc in occComposition.ts).",
      "items": {
        "$ref": "#/$defs/occSpecialization"
      }
    },
    "occSkillsCore": {
      "type": "array",
      "description": "O.C.C. skills granted automatically at creation — fixed skillId grants and/or open-choice vouchers (W.P. of choice, pick N from categories).",
      "items": {
        "$ref": "#/$defs/occCoreSkillEntry"
      }
    },
    "occRelatedSkills": {
      "$ref": "#/$defs/occRelatedSkills"
    },
    "secondarySkills": {
      "$ref": "#/$defs/secondarySkills"
    },
    "levelUpSkillChoices": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/levelUpSkillChoice"
      }
    },
    "wpRules": {
      "$ref": "#/$defs/wpRules"
    },
    "handToHandRules": {
      "$ref": "#/$defs/handToHandRules"
    },
    "classAbilities": {
      "type": "array",
      "description": "Unique O.C.C. abilities and special skills not represented as skill catalog rows (e.g. Recognize the Supernatural, Special Anti-Supernatural Bonuses).",
      "items": {
        "$ref": "#/$defs/classAbility"
      }
    },
    "staticBonuses": {
      "$ref": "#/$defs/staticBonuses"
    },
    "ppeEngine": {
      "$ref": "#/$defs/ppeEngine"
    },
    "ispEngine": {
      "$ref": "#/$defs/ispEngine"
    },
    "customAbilityEngines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/customAbilityEngine"
      }
    },
    "startingEquipment": {
      "$ref": "#/$defs/startingEquipment"
    },
    "finances": {
      "$ref": "#/$defs/finances"
    },
    "progression": {
      "$ref": "#/$defs/progressionHooks",
      "description": "Optional engine hooks (XP table, psychic gate, slot budgets) until all flows read composition blocks directly."
    },
    "baseStats": {
      "$ref": "#/$defs/baseStatsDice",
      "description": "Optional chargen dice summary for UI (legacy display); prefer staticBonuses and supernatural engines when modeled."
    },
    "creationSubForgeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "When set, master character creation Tab 6 hosts this sub-forge manifest (overrides race default)."
    },
    "packageNotes": {
      "type": "array",
      "description": "Player-facing O.C.C. package summary notes (e.g. recommended attributes, race prerequisites) shown in the configurator detail panel.",
      "items": { "type": "string", "minLength": 1 }
    },
    "supernaturalRuleOverrides": {
      "$ref": "#/$defs/supernaturalRuleOverrides"
    }
  },
  "$defs": {
    "spellCaveat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["focus", "target", "ppe", "ritual", "note"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "sourcePage": { "type": "integer", "minimum": 1 }
      }
    },
    "occSpellAccessRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["school", "accessType"],
      "properties": {
        "school": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "description": "Foreign school slug to borrow from (e.g. wizard)."
        },
        "accessType": {
          "type": "string",
          "enum": ["only", "except"],
          "description": "only = matching spells allowed; except = all in school except spellIds."
        },
        "tagFilter": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "description": "Semantic filter (e.g. affects_flesh) matched against spell tags and spellAccess."
        },
        "spellIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^magic_" },
          "uniqueItems": true
        },
        "crossListId": {
          "type": "string",
          "minLength": 1,
          "description": "Key in content/magic_cross_lists.json for enumerated borrow lists."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "UI label for this borrow rule."
        },
        "defaultCaveats": {
          "type": "array",
          "items": { "$ref": "#/$defs/spellCaveat" }
        }
      }
    },
    "catalogSkillId": {
      "type": "string",
      "pattern": "^skill_[a-z][a-z0-9_]*$",
      "description": "Reference to a row in the skills catalog (`src/data/content/skills/*.json`)."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gameSystem", "reference", "pageNumber"],
        "properties": {
          "gameSystem": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 1
          },
          "reference": {
            "type": "string",
            "minLength": 1
          },
          "pageNumber": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "attributeKey": {
      "type": "string",
      "enum": ["iq", "me", "ma", "ps", "pp", "pe", "pb", "spd"]
    },
    "attributeRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "iq": { "type": "integer" },
        "me": { "type": "integer" },
        "ma": { "type": "integer" },
        "ps": { "type": "integer" },
        "pp": { "type": "integer" },
        "pe": { "type": "integer" },
        "pb": { "type": "integer" },
        "spd": { "type": "integer" }
      }
    },
    "alignmentRestrictions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "forbidden": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "raceRestrictions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "occCoreSkillGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillId", "bonusPercent"],
      "properties": {
        "skillId": {
          "$ref": "#/$defs/catalogSkillId"
        },
        "bonusPercent": {
          "type": "integer",
          "description": "Fixed additive % on top of normal O.C.C. skill base resolution."
        },
        "basePercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 98,
          "description": "Optional flat starting % when the book gives a fixed O.C.C. skill baseline."
        }
      }
    },
    "occCoreSkillChoiceVoucher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["choiceCount", "bonusPercent"],
      "properties": {
        "choiceCount": {
          "type": "integer",
          "minimum": 1,
          "description": "How many skills the player must select from the allowed pool (counts toward O.C.C. core slot budget)."
        },
        "bonusPercent": {
          "type": "integer",
          "description": "Additive % applied to each skill resolved from this voucher."
        },
        "allowedCategories": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "description": "Restrict picks to skills whose skill catalog `categories[]` includes any listed category."
        },
        "allowedSkillIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true,
          "description": "Restrict picks to an explicit allow-list (e.g. weapon proficiency ids for W.P. of choice)."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Player-facing summary for creation UI (e.g. \"W.P. of choice\", \"Two Medical, Science, or Technical skills\")."
        },
        "weaponProficiencyEra": {
          "type": "string",
          "enum": ["ancient", "modern"],
          "description": "Optional era lock for Weapon Proficiencies vouchers. When set, only ancient or modern W.P. ids are eligible; omit to allow the player to toggle era in creation UI."
        },
        "allowedSkillTraits": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Restrict picks to catalog skills tagged with any listed trait (skill_trait_registry.json / skill_trait_lists/*.txt)."
        }
      },
      "anyOf": [
        { "required": ["allowedCategories"] },
        { "required": ["allowedSkillIds"] },
        { "required": ["allowedSkillTraits"] }
      ]
    },
    "occCoreSkillEntry": {
      "oneOf": [
        { "$ref": "#/$defs/occCoreSkillGrant" },
        { "$ref": "#/$defs/occCoreSkillChoiceVoucher" }
      ],
      "description": "Either a fixed catalog skill grant or an open-choice voucher in the automatic core package."
    },
    "supernaturalGrantedAbilityIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Spells, psionics, or talents auto-granted at creation; do not consume progressionRoadmap selection budget."
    },
    "occRelatedSkillCategoryMinimum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categoryName", "minimumCount"],
      "properties": {
        "categoryName": {
          "type": "string",
          "minLength": 1,
          "description": "Skill category label (matches skill catalog `categories[]`)."
        },
        "minimumCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum related-skill picks required from this category at creation."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Player-facing summary (e.g. \"Two must be from Science\")."
        }
      }
    },
    "occClassAbilityPercentileProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basePercent", "perLevelPercent"],
      "properties": {
        "basePercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 98
        },
        "perLevelPercent": {
          "type": "integer",
          "description": "Additive % per character level (e.g. Understand the Principles of Magic +2%/level)."
        },
        "skillId": {
          "type": "string",
          "pattern": "^skill_[a-z][a-z0-9_]*$",
          "description": "Optional catalog skill anchor when a matching skill catalog row exists."
        }
      }
    },
    "occCategoryAccessRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categoryName", "accessType", "bonusPercent"],
      "properties": {
        "categoryName": {
          "type": "string",
          "minLength": 1,
          "description": "Skill category label (matches skill catalog `categories[]`)."
        },
        "accessType": {
          "type": "string",
          "enum": ["any", "none", "only", "except"],
          "description": "Category-wide access; exceptions override per skillId."
        },
        "exceptions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true,
          "description": "Skill ids that override accessType for this category row."
        },
        "bonusPercent": {
          "type": "integer",
          "description": "O.C.C. related-skill % bonus when picking from this category (if applicable)."
        },
        "skillSpecificOverrides": {
          "type": "object",
          "description": "Per-skill % bonuses that supersede bonusPercent for listed skill ids (e.g. Languages +10% inside Technical +5%).",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "integer"
          }
        },
        "selectionSlotCost": {
          "type": "integer",
          "minimum": 1,
          "description": "Related/secondary skill slots consumed per pick from this category (default 1). Distinct from professional-quality repeat tiers."
        },
        "skillSpecificSelectionSlotCosts": {
          "type": "object",
          "description": "Per-skill slot costs that override selectionSlotCost for listed ids (e.g. Medical default 2, First Aid 1).",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "occRelatedSkillsOverride": {
      "type": "object",
      "additionalProperties": false,
      "description": "Partial related-skill block merged when a specialization is active.",
      "properties": {
        "initialSlotsCount": { "type": "integer", "minimum": 0 },
        "startingSkillIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/catalogSkillId"
          },
          "uniqueItems": true
        },
        "categoryRules": {
          "type": "array",
          "items": { "$ref": "#/$defs/occCategoryAccessRule" }
        },
        "categoryMinimums": {
          "type": "array",
          "items": { "$ref": "#/$defs/occRelatedSkillCategoryMinimum" }
        }
      }
    },
    "occSpecialization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Stable branch slug (e.g. ada_spy_specialist, team_epsilon)."
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "staticBonuses": {
          "$ref": "#/$defs/staticBonuses",
          "description": "Merged into baseline staticBonuses: numbers add per key; dice/formula strings on a key replace any prior value for that key."
        },
        "startingEquipment": {
          "$ref": "#/$defs/startingEquipment",
          "description": "When present, **replaces** baseline startingEquipment for this branch (e.g. ADA rifle package vs spy surveillance kit)."
        },
        "finances": {
          "$ref": "#/$defs/finances",
          "description": "Field-wise override of baseline finances (e.g. different starting cash formula per branch)."
        },
        "occSkillsCore": {
          "type": "array",
          "description": "When present, **replaces** baseline occSkillsCore for this branch (forced packages like ADA specialists).",
          "items": { "$ref": "#/$defs/occCoreSkillEntry" }
        },
        "occRelatedSkills": {
          "$ref": "#/$defs/occRelatedSkillsOverride",
          "description": "Merged into baseline related skills (category rules override by categoryName)."
        },
        "wpRules": {
          "$ref": "#/$defs/wpRules",
          "description": "Merged into baseline W.P. rules (coreWps union; forbiddenWps union)."
        },
        "handToHandRules": {
          "$ref": "#/$defs/handToHandRules",
          "description": "Overrides baseline hand-to-hand when present (e.g. ADA Spy → Martial Arts, Assassin → Assassin)."
        },
        "classAbilities": {
          "type": "array",
          "description": "Branch-specific abilities appended to baseline classAbilities when this specialization is active.",
          "items": {
            "$ref": "#/$defs/classAbility"
          }
        }
      }
    },
    "classAbility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "percentileProfile": {
          "$ref": "#/$defs/occClassAbilityPercentileProfile",
          "description": "Structured percentile O.C.C. ability (e.g. Understand the Principles of Magic 70% +2%/level)."
        }
      }
    },
    "occRelatedSkills": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initialSlotsCount", "categoryRules"],
      "properties": {
        "initialSlotsCount": {
          "type": "integer",
          "minimum": 0
        },
        "startingSkillIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/catalogSkillId"
          },
          "uniqueItems": true,
          "description": "Optional pre-selected related skills at creation (bootstrap for Skill Engine)."
        },
        "categoryRules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/occCategoryAccessRule"
          }
        },
        "categoryMinimums": {
          "type": "array",
          "items": { "$ref": "#/$defs/occRelatedSkillCategoryMinimum" },
          "description": "Mandatory related-skill category quotas at creation (e.g. two Science skills)."
        }
      }
    },
    "secondarySkills": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initialSlotsCount", "forbiddenCategories"],
      "properties": {
        "initialSlotsCount": {
          "type": "integer",
          "minimum": 0
        },
        "forbiddenCategories": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "levelUpSkillChoice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["levelUnlocked", "quantity", "poolSource"],
      "properties": {
        "levelUnlocked": {
          "type": "integer",
          "minimum": 2
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        },
        "poolSource": {
          "type": "string",
          "enum": ["related", "secondary"]
        }
      }
    },
    "wpRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coreWps", "forbiddenWps"],
      "properties": {
        "coreWps": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true,
          "description": "Weapon proficiency ids granted at creation."
        },
        "forbiddenWps": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "handToHandUpgradePath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetSkillId", "electiveSlotCost"],
      "properties": {
        "targetSkillId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "electiveSlotCost": {
          "type": "integer",
          "minimum": 0,
          "description": "Related or secondary slots spent to acquire this hand-to-hand tier."
        },
        "alignmentRestrictions": {
          "$ref": "#/$defs/alignmentRestrictions",
          "description": "When set, path is only offered when character alignment satisfies allowed/forbidden (e.g. Assassin for evil alignments)."
        }
      }
    },
    "handToHandRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upgradePaths"],
      "properties": {
        "defaultSkillId": {
          "description": "Starting Hand-to-Hand combat catalog id. **Omit or use `hth_none`** for untrained baseline brawling (2 APM per attack). Use `hand_to_hand_*` sheet ids or `hth_*` catalog ids when the O.C.C. grants formal training. **null** when no style is granted at creation and the player must purchase a tier via `upgradePaths` / electives.",
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$",
              "default": "hth_none"
            },
            { "type": "null" }
          ]
        },
        "upgradePaths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/handToHandUpgradePath"
          }
        }
      }
    },
    "staticBonusValue": {
      "description": "Flat integer bonus or dice/formula string (e.g. 20, \"1D4\", \"4D6+25\") parsed at chargen.",
      "oneOf": [
        { "type": "number" },
        {
          "type": "string",
          "minLength": 1,
          "description": "Dice notation or expression — not summed with other values; replaces the key when merging specializations."
        }
      ]
    },
    "numericBonusMap": {
      "type": "object",
      "description": "Open-ended modifiers (attributes, vitals, combat, saves). Values are numbers (additive on merge) or formula strings (replace on merge).",
      "additionalProperties": {
        "$ref": "#/$defs/staticBonusValue"
      }
    },
    "staticBonuses": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attributes": {
          "$ref": "#/$defs/numericBonusMap"
        },
        "vitals": {
          "$ref": "#/$defs/numericBonusMap",
          "description": "Flat H.P., S.D.C., P.P.E., I.S.P., etc."
        },
        "combat": {
          "$ref": "#/$defs/numericBonusMap",
          "description": "Strike, parry, dodge, initiative, perception, A.P.M., etc."
        },
        "saves": {
          "$ref": "#/$defs/numericBonusMap",
          "description": "save_poison, save_magic, save_psionics, etc."
        },
        "levelGatedSaves": {
          "type": "object",
          "description": "Per-save additive bonuses unlocked at character levels (keys summed when level ≥ milestone).",
          "additionalProperties": {
            "$ref": "#/$defs/spellStrengthProgression"
          },
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    },
    "supernaturalSelectionModePool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "selections", "categories"],
      "properties": {
        "kind": { "const": "pool" },
        "selections": { "type": "integer", "minimum": 1 },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Psionic pool ids (sensitive, physical, healer, super) or spell restriction tags."
        }
      }
    },
    "supernaturalSelectionModePerCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "buckets"],
      "properties": {
        "kind": { "const": "per_category" },
        "buckets": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          },
          "description": "Independent pick counts per category (e.g. sensitive: 2, physical: 2, healer: 2)."
        }
      }
    },
    "supernaturalSelectionModeSingleCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "selections", "categories"],
      "properties": {
        "kind": { "const": "single_category" },
        "selections": { "type": "integer", "minimum": 1 },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Player locks one category from this list, then selects N powers from that pool (Psychic Gate minor/major single-pool model)."
        }
      }
    },
    "supernaturalSelectionMode": {
      "oneOf": [
        { "$ref": "#/$defs/supernaturalSelectionModePool" },
        { "$ref": "#/$defs/supernaturalSelectionModePerCategory" },
        { "$ref": "#/$defs/supernaturalSelectionModeSingleCategory" }
      ]
    },
    "supernaturalCreationSelectionStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selectionsGained", "selectionMode"],
      "properties": {
        "selectionsGained": {
          "type": "integer",
          "minimum": 1,
          "description": "Redundant with mode.selections / sum(buckets) for validation; kept for legacy budget rollups."
        },
        "selectionMode": {
          "$ref": "#/$defs/supernaturalSelectionMode"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Player-facing summary for package summary / abilities forge."
        }
      }
    },
    "supernaturalPerLevelSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fromLevel", "selectionsGained", "selectionMode"],
      "properties": {
        "fromLevel": {
          "type": "integer",
          "minimum": 2,
          "description": "First character level that receives this repeating grant (inclusive)."
        },
        "toLevel": {
          "type": "integer",
          "minimum": 2,
          "description": "Last character level that receives this grant (inclusive). Omit for no upper cap within campaign level band."
        },
        "selectionsGained": {
          "type": "integer",
          "minimum": 1
        },
        "selectionMode": {
          "$ref": "#/$defs/supernaturalSelectionMode"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "supernaturalRuleOverrideLeyLine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "useGlobalDefault": {
          "type": "boolean",
          "description": "When true or omitted, display global ley-line psionic modifiers. When false, use local multipliers and notes."
        },
        "rangeDurationNearLeyLineMultiplier": { "type": "number", "minimum": 0 },
        "rangeDurationAtNexusMultiplier": { "type": "number", "minimum": 0 },
        "damageAtNexusMultiplier": { "type": "number", "minimum": 0 },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "supernaturalRuleOverrideMeditation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "useGlobalDefault": { "type": "boolean" },
        "ispPerHour": { "type": "integer", "minimum": 0 },
        "sleepRestIspPerHour": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "supernaturalRuleOverridePsychicApm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "useGlobalDefault": { "type": "boolean" },
        "linkedToHandToHand": {
          "type": "boolean",
          "description": "When true, psionic attacks per melee equal hand-to-hand APM unless adjusted below."
        },
        "bonusTotalActions": {
          "type": "integer",
          "description": "Additive APM usable for any action including psionics."
        },
        "additionalPsionicOnlyActions": {
          "type": "integer",
          "minimum": 0,
          "description": "Extra melee actions that may only be spent on psionic powers."
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "supernaturalRuleOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "leyLine": { "$ref": "#/$defs/supernaturalRuleOverrideLeyLine" },
        "meditation": { "$ref": "#/$defs/supernaturalRuleOverrideMeditation" },
        "psychicApm": { "$ref": "#/$defs/supernaturalRuleOverridePsychicApm" }
      }
    },
    "supernaturalEngineSelectionFields": {
      "type": "object",
      "properties": {
        "creationSelectionPlan": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/supernaturalCreationSelectionStep" },
          "description": "Structured 1st-level supernatural pick plan (replaces verbose duplicate progressionRoadmap rows when set)."
        },
        "perLevelSelection": {
          "$ref": "#/$defs/supernaturalPerLevelSelection",
          "description": "Repeating per-level supernatural grants (e.g. +1 psionic/level from any minor category)."
        }
      }
    },
    "supernaturalProgressionStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "selectionsGained"],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "selectionsGained": {
          "type": "integer",
          "minimum": 0
        },
        "categoryRestrictions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "description": "Legacy restriction tags (e.g. Level 1 Spells Only, Sensitive Only). Prefer creationSelectionPlan when authoring new rows."
        },
        "selectionMode": {
          "$ref": "#/$defs/supernaturalSelectionMode",
          "description": "Optional structured mode on a single roadmap step (alternative to flat categoryRestrictions)."
        }
      }
    },
    "spellStrengthProgression": {
      "type": "object",
      "description": "Maps character level (string key) to active Spell Strength.",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "propertyNames": {
        "pattern": "^[0-9]+$"
      }
    },
    "ppeEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseFormula", "perLevelFormula", "progressionRoadmap"],
      "properties": {
        "baseFormula": {
          "type": "string",
          "minLength": 1,
          "description": "e.g. 1D4*10 + PE"
        },
        "perLevelFormula": {
          "type": "string",
          "minLength": 1,
          "description": "e.g. 2D6 per level."
        },
        "spellStrengthProgression": {
          "$ref": "#/$defs/spellStrengthProgression"
        },
        "progressionRoadmap": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supernaturalProgressionStep"
          }
        },
        "magicSchools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Native magic schools this O.C.C. may learn (e.g. wizard, fleshsculptor). When omitted with no spellAccessRules, school is not gated."
        },
        "spellAccessRules": {
          "type": "array",
          "items": { "$ref": "#/$defs/occSpellAccessRule" },
          "description": "Cross-school borrow rules (e.g. Mirrormage wizard spells via mirror focus). Spells with no access path are hidden in UI."
        },
        "grantedAbilityIds": {
          "$ref": "#/$defs/supernaturalGrantedAbilityIds"
        },
        "spellAcquisition": {
          "type": "string",
          "enum": ["open", "roadmap_only"],
          "description": "open = may learn/purchase spells of any level anytime (Sorcerer); roadmap_only = intuitive roadmap picks only (Mystic)."
        },
        "creationSelectionPlan": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/supernaturalCreationSelectionStep" }
        },
        "perLevelSelection": {
          "$ref": "#/$defs/supernaturalPerLevelSelection"
        }
      }
    },
    "ispEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseFormula", "perLevelFormula", "savingThrowClass", "progressionRoadmap"],
      "properties": {
        "baseFormula": {
          "type": "string",
          "minLength": 1
        },
        "perLevelFormula": {
          "type": "string",
          "minLength": 1
        },
        "savingThrowClass": {
          "type": "string",
          "enum": ["minor", "major", "master"],
          "description": "Psychic save tier baseline for this O.C.C."
        },
        "progressionRoadmap": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supernaturalProgressionStep"
          }
        },
        "grantedAbilityIds": {
          "$ref": "#/$defs/supernaturalGrantedAbilityIds"
        },
        "creationSelectionPlan": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/supernaturalCreationSelectionStep" }
        },
        "perLevelSelection": {
          "$ref": "#/$defs/supernaturalPerLevelSelection"
        }
      }
    },
    "customAbilityEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engineId", "label", "progressionRoadmap"],
      "properties": {
        "engineId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Stable key (e.g. nightbane_talents, class_abilities)."
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "baseFormula": {
          "type": "string",
          "minLength": 1
        },
        "perLevelFormula": {
          "type": "string",
          "minLength": 1
        },
        "progressionRoadmap": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supernaturalProgressionStep"
          }
        },
        "creationSelectionPlan": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/supernaturalCreationSelectionStep" }
        },
        "perLevelSelection": {
          "$ref": "#/$defs/supernaturalPerLevelSelection"
        }
      }
    },
    "startingEquipment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weapons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Item ids or narrative descriptors."
        },
        "armor": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "miscellaneous": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "finances": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startingCashFormula": {
          "type": "string",
          "minLength": 1,
          "description": "e.g. 1D6*100"
        },
        "blackMarketAssets": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "progressionHooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "xpTableId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Catalog id in content/progression/xp_tables/<genre>/ (e.g. between_shadows_arcane_detective)."
        },
        "characterOccCategory": {
          "type": "string",
          "enum": ["psychic", "standard"],
          "description": "Drives Psychic Gate lock and CharacterOcc.category on the sheet."
        },
        "psychicGateBypassed": { "type": "boolean" },
        "relatedSkillSlotPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["fixed", "psychic_tier"]
            },
            "multiplier": { "type": "number", "minimum": 0 },
            "majorMultiplier": { "type": "number", "minimum": 0 },
            "defaultMultiplier": { "type": "number", "minimum": 0 }
          },
          "allOf": [
            {
              "if": {
                "properties": { "kind": { "const": "fixed" } },
                "required": ["kind"]
              },
              "then": { "required": ["multiplier"] }
            },
            {
              "if": {
                "properties": { "kind": { "const": "psychic_tier" } },
                "required": ["kind"]
              },
              "then": { "required": ["majorMultiplier"] }
            }
          ]
        },
        "occSkillSlotBudget": { "type": "integer", "minimum": 0 },
        "occRelatedSkillSlotBudget": { "type": "integer", "minimum": 0 },
        "creationAbilityBudget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "spellSlots": { "type": "integer", "minimum": 0 },
            "psionicSlots": { "type": "integer", "minimum": 0 },
            "talentSlots": { "type": "integer", "minimum": 0 }
          }
        },
        "startingSpellLevelCap": { "type": "integer", "minimum": 0 }
      }
    },
    "baseStatsDice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hpDice": { "type": "string", "minLength": 1 },
        "sdcDice": { "type": "string", "minLength": 1 },
        "ppeDice": { "type": "string", "minLength": 1 },
        "ispDice": { "type": "string", "minLength": 1 }
      }
    }
  }
}
