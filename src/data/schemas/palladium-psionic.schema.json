{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://megaverse-companion.local/schemas/palladium-psionic.schema.json",
  "title": "Palladium psionic ability",
  "description": "Psionic power catalog row (Nightbane RPG pp. 70–84 pattern; Rifts/Heroes variants via genre placement). Documents I.S.P. economy (including `dynamicCosts`), range/duration/save, restorative `healing` and offensive `damage` (including `attackProfiles`), self-inflicted `backlash`, percentile base skills, trance preparation, compound sub-abilities, and optional mechanical automation (`resolutionTable` structured object or legacy entry array, `permanentCosts`, `spawnedPresence`, `formTransformation`, legacy `summonedEntity`, `grantedModifiers`, `inflictedModifiers`). Shared fragments live in `palladium-feature-common.schema.json`. Runtime importers map rows to the universal Feature composer (`metadata.pickBucket`: `psionic`). **Genre placement** records which selection category each power belongs to per setting — Nightbane uses *Sensitive*, *Physical*, and *Healer*; other Megaversal settings may classify the same power differently.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "description",
    "gameSystems",
    "sources",
    "genrePlacements"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "minLength": 1,
      "description": "Canonical catalog id (e.g. `psionic_mind_block`)."
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "descriptionMorphus": { "type": "string", "minLength": 1 },
    "gameSystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "genrePlacements": {
      "type": "array",
      "minItems": 1,
      "description": "Per-genre selection category (and optional mechanical overrides when the same power appears in multiple categories or with different costs). Nightbane Psychic P.C.C. picks two powers from each of Sensitive, Physical, and Healer at 1st level (pp. 70–71).",
      "items": { "$ref": "#/$defs/psionicGenrePlacement" }
    },
    "innateStarter": {
      "type": "boolean",
      "description": "True when the power is granted automatically at 1st level for a psychic O.C.C./P.C.C. (e.g. See Aura, Sense Evil, Meditation, Presence Sense on Nightbane p. 70)."
    },
    "isp": { "$ref": "#/$defs/psionicIspEconomy" },
    "limitations": { "$ref": "#/$defs/psionicLimitations" },
    "ranges": {
      "type": "array",
      "items": { "$ref": "#/$defs/psionicRangeEntry" }
    },
    "range": { "$ref": "#/$defs/proseBlock" },
    "duration": { "$ref": "#/$defs/psionicDuration" },
    "areaOfEffect": { "$ref": "#/$defs/proseBlock" },
    "damage": {
      "oneOf": [
        { "$ref": "#/$defs/psionicDamage" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "healing": {
      "description": "Hit point and S.D.C. restoration formulas for healer psionic powers (e.g. Healing Touch, Psychic Surgery).",
      "$ref": "#/$defs/psionicHealing"
    },
    "save": {
      "oneOf": [
        { "$ref": "#/$defs/psionicSaveEntry" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/psionicSaveEntry" }
        },
        { "type": "string", "minLength": 1 }
      ]
    },
    "lengthOfTrance": { "$ref": "#/$defs/lengthOfTrance" },
    "preparation": { "$ref": "#/$defs/psionicPreparation" },
    "baseSkill": {
      "oneOf": [
        { "$ref": "#/$defs/psionicBaseSkill" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/psionicBaseSkill" }
        }
      ]
    },
    "combatBonuses": { "$ref": "#/$defs/passiveModifiers" },
    "resolutionTable": {
      "description": "Percentile or dice outcome bands mapped to mechanical effects. Prefer the structured object form; legacy flat `entries` arrays remain valid.",
      "oneOf": [
        { "$ref": "#/$defs/psionicLegacyResolutionTable" },
        { "$ref": "#/$defs/psionicResolutionTable" }
      ]
    },
    "permanentCosts": {
      "type": "array",
      "description": "Irreversible maximum-pool or attribute sacrifices applied once when the power succeeds (distinct from `isp` activation cost).",
      "minItems": 1,
      "items": {
        "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/permanentCostEntry"
      }
    },
    "spawnedPresence": {
      "description": "Construct or catalog creature spawned by the power (`kind`: `construct` | `creature`). Prefer over legacy `summonedEntity`.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresence"
    },
    "formTransformation": {
      "description": "Temporary sheet replacement while the power is active. Distinct from `grantedModifiers` overlay buffs.",
      "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/formTransformation"
    },
    "summonedEntity": {
      "description": "Deprecated construct alias — treat as `spawnedPresence` with `kind: construct`. Retained for backward compatibility (e.g. Astral Projection Silver Cord).",
      "$ref": "#/$defs/psionicSummonedEntity"
    },
    "grantedModifiers": {
      "description": "Temporary buffs, movement capabilities, and immunities granted while the power is active. Use `target` when the recipient is not the psychic (e.g. Deaden Pain on an ally).",
      "$ref": "#/$defs/psionicGrantedModifiers"
    },
    "inflictedModifiers": {
      "description": "Debuffs and conditions applied to targets by offensive powers (e.g. Bio-Manipulation Blind or Stun).",
      "$ref": "#/$defs/psionicInflictedModifiers"
    },
    "backlash": {
      "description": "Self-inflicted damage or penalties the psychic risks when using the power (e.g. Telekinetic Leap wrenched muscles).",
      "$ref": "#/$defs/psionicBacklash"
    },
    "subAbilities": {
      "type": "array",
      "description": "Compound powers with numbered or named modes (Pyrokinesis, Electrokinesis, Bio-Manipulation effects, Empathy transmissions, Divination methods, etc.).",
      "items": { "$ref": "#/$defs/psionicSubAbility" }
    },
    "prerequisites": {
      "type": "array",
      "items": { "$ref": "#/$defs/psionicPrerequisite" }
    },
    "incompatiblePsionicIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
      "uniqueItems": true
    },
    "notes": { "type": "string", "minLength": 1 },
    "formRequirement": {
      "type": "string",
      "enum": ["morphus", "facade", "either"]
    },
    "activation": { "$ref": "#/$defs/psionicActivation" },
    "durationType": {
      "type": "string",
      "enum": ["instant", "melee", "narrative", "permanent", "concentration"]
    },
    "pumpable": { "$ref": "#/$defs/pumpRule" }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameSystem", "reference", "pageNumber"],
      "properties": {
        "gameSystem": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "minLength": 1
        },
        "reference": { "type": "string", "minLength": 1 },
        "pageNumber": { "type": "integer", "minimum": 1 }
      }
    },
    "proseBlock": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "psionicCategory": {
      "type": "string",
      "enum": [
        "sensitive",
        "physical",
        "healer",
        "healing",
        "super"
      ],
      "description": "Selection pool category. Nightbane core book uses `sensitive`, `physical`, and `healer` (pp. 70–71, 84). Other settings often use `healing` instead of `healer`, and Rifts adds `super` psionics."
    },
    "psionicGenrePlacement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["genreId", "category"],
      "properties": {
        "genreId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "description": "Setting slug (`nightbane`, `rifts`, `palladium_fantasy`, `heroes_unlimited`, …)."
        },
        "category": { "$ref": "#/$defs/psionicCategory" },
        "isp": {
          "description": "Optional override when this genre/category placement uses different I.S.P. than the row default (e.g. Death Trance: 2 I.S.P. Sensitive vs 1 I.S.P. Physical on Nightbane p. 73 vs 79).",
          "$ref": "#/$defs/psionicIspEconomy"
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Genre-specific placement notes (e.g. 'Identical to Sensitive Suggestion' on Healer p. 85)."
        }
      }
    },
    "psionicIspEconomy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "baseActivation": {
          "description": "I.S.P. spent to activate (fixed integer, dice/prose, `none`, or structured relative cost).",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "perLevel": {
          "description": "Additional I.S.P. scaling per level of experience.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "perTarget": {
          "description": "Per-target or per-idea surcharge (e.g. Suggestion 2 I.S.P. per idea, Empathic Transmission per emotion).",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "perMinute": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "recallBlockCost": {
          "description": "Follow-up cost after initial activation (e.g. Total Recall 3 I.S.P. per information block after the 2 I.S.P. acquisition cost).",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "notes": { "type": "string", "minLength": 1 },
        "dynamicCosts": {
          "type": "array",
          "description": "Formulaic costs that scale based on external factors like weight, distance, or target size (e.g. Telekinesis: 6 I.S.P. for the first 20 lbs, plus 1 I.S.P. per additional 10 lbs).",
          "items": { "$ref": "#/$defs/psionicDynamicCostEntry" }
        },
        "enhancement": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "costPerStep": { "type": "integer", "minimum": 0 },
            "stepDefinition": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "psionicDynamicCostEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "costFormula"],
      "properties": {
        "trigger": {
          "type": "string",
          "minLength": 1,
          "description": "Condition that activates this cost tier (e.g. `Weight: > 20 lbs`)."
        },
        "costFormula": {
          "type": "string",
          "minLength": 1,
          "description": "Incremental I.S.P. formula when the trigger applies (e.g. `+1 I.S.P. per 10 lbs`)."
        }
      }
    },
    "psionicLimitations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "selfOnly": { "type": "boolean" },
        "cannotAffectSelf": { "type": "boolean" },
        "lineOfSightRequired": { "type": "boolean" },
        "concentrationRequired": { "type": "boolean" },
        "attacksPerMeleeLimit": { "type": "string", "minLength": 1 },
        "cannotUseWhile": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "otherLimitations": { "type": "string", "minLength": 1 }
      }
    },
    "psionicRangeEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "touch",
            "distance",
            "self",
            "radius",
            "line_of_sight",
            "area",
            "special"
          ]
        },
        "distanceValue": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "distanceUnit": {
          "type": "string",
          "enum": ["foot", "feet", "mile", "miles", "meter", "meters"]
        },
        "distancePerLevel": { "type": "number", "minimum": 0 }
      }
    },
    "psionicDuration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "instant",
            "melee_round",
            "minute",
            "hour",
            "day",
            "permanent",
            "until_condition",
            "special"
          ]
        },
        "durationValue": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "perLevel": { "type": "string", "minLength": 1 }
      }
    },
    "psionicSaveEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "saveKind": {
          "type": "string",
          "enum": [
            "standard",
            "psionic",
            "magic",
            "none",
            "conditional",
            "special"
          ]
        },
        "targetNumber": { "type": "integer", "minimum": 1 },
        "bonus": { "type": "string", "minLength": 1 },
        "effectsOnFailedSave": { "type": "string", "minLength": 1 },
        "effectsOnSuccessfulSave": { "type": "string", "minLength": 1 }
      }
    },
    "psionicDamageAttackProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "formula"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Attack option label (e.g. Telekinetic Punch, Telekinetic Kick)."
        },
        "formula": {
          "type": "string",
          "minLength": 1,
          "description": "Damage dice or formula for this attack profile (e.g. 4D6 + P.S. bonus)."
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Combat modifiers or constraints specific to this profile."
        }
      }
    },
    "psionicDamage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "formula": {
          "type": "string",
          "minLength": 1,
          "description": "Single damage formula for simple powers (backward compatible shorthand)."
        },
        "primaryTargetDamage": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "attackProfiles": {
          "type": "array",
          "description": "Distinct attack options when one power offers multiple damage profiles (e.g. Telekinetic Punch vs. Telekinetic Kick).",
          "minItems": 1,
          "items": { "$ref": "#/$defs/psionicDamageAttackProfile" }
        }
      }
    },
    "psionicBacklash": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structures self-inflicted damage or penalties caused by using the power.",
      "properties": {
        "damageFormula": {
          "type": "string",
          "minLength": 1,
          "description": "Self-inflicted damage dice or formula (e.g. 1D6, 2D6)."
        },
        "saveToAvoid": {
          "description": "Save target to avoid or reduce backlash (prose or numeric target).",
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Narrative edge cases (e.g. damage is from wrenched muscles)."
        }
      }
    },
    "psionicHealing": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structures hit point and S.D.C. restoration for healer psionic powers.",
      "properties": {
        "hpFormula": {
          "type": "string",
          "minLength": 1,
          "description": "Dice or formula restoring hit points (e.g. `1D8`)."
        },
        "sdcFormula": {
          "type": "string",
          "minLength": 1,
          "description": "Dice or formula restoring S.D.C. (e.g. `2D6`)."
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Edge cases, limits, or conditional restoration rules."
        }
      }
    },
    "lengthOfTrance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "preparationMinutes": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "preparationMelees": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "activeMinutes": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "psionicPreparation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "minutes": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "melees": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "requiresMeditation": { "type": "boolean" }
      }
    },
    "psionicBaseSkill": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Skill check name (e.g. Impressions, Present, Success Ratio)."
        },
        "basePercent": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 98 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "perLevel": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "psionicSubAbility": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "index": { "type": "integer", "minimum": 1 },
        "description": { "type": "string", "minLength": 1 },
        "isp": { "$ref": "#/$defs/psionicIspEconomy" },
        "range": { "$ref": "#/$defs/proseBlock" },
        "duration": { "$ref": "#/$defs/psionicDuration" },
        "save": { "$ref": "#/$defs/psionicSaveEntry" },
        "damage": { "$ref": "#/$defs/psionicDamage" },
        "combatBonuses": { "$ref": "#/$defs/passiveModifiers" },
        "baseSkill": { "$ref": "#/$defs/psionicBaseSkill" },
        "resolutionTable": {
          "oneOf": [
            { "$ref": "#/$defs/psionicLegacyResolutionTable" },
            { "$ref": "#/$defs/psionicResolutionTable" }
          ]
        },
        "spawnedPresence": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresence"
        },
        "formTransformation": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/formTransformation"
        },
        "grantedModifiers": { "$ref": "#/$defs/psionicGrantedModifiers" },
        "inflictedModifiers": { "$ref": "#/$defs/psionicInflictedModifiers" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "passiveModifiers": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "psionicLegacyResolutionTable": {
      "type": "array",
      "description": "Legacy flat resolution table — prefer structured `psionicResolutionTable` for new content.",
      "minItems": 1,
      "items": {
        "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/resolutionTableEntry"
      }
    },
    "psionicResolutionTableEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect"],
      "description": "Psionic resolution table row — extends common `resolutionTableEntry` with optional modifier automation and nested follow-up tables.",
      "properties": {
        "percentile": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/percentileRange"
        },
        "rollRange": {
          "type": "string",
          "minLength": 1,
          "description": "Authoring shorthand for an outcome band (e.g. `01-20`, `77-00`)."
        },
        "label": { "type": "string", "minLength": 1 },
        "effect": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "grantedModifiers": { "$ref": "#/$defs/psionicGrantedModifiers" },
        "inflictedModifiers": { "$ref": "#/$defs/psionicInflictedModifiers" },
        "followUpTable": { "$ref": "#/$defs/psionicResolutionTable" }
      },
      "oneOf": [
        { "required": ["percentile"] },
        { "required": ["rollRange"] }
      ]
    },
    "psionicResolutionTable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries"],
      "properties": {
        "rollKind": {
          "type": "string",
          "enum": ["d100", "d20", "d6", "d4", "other"]
        },
        "label": { "type": "string", "minLength": 1 },
        "resolutionTrigger": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/resolutionTrigger"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/psionicResolutionTableEntry" }
        }
      }
    },
    "psionicSummonedEntity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Legacy construct shape — equivalent to `spawnedPresence` with `kind: construct` without requiring the discriminant field.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Label for the spawned entity (e.g. Astral Body, Silver Cord, Ectoplasm Construct)."
        },
        "derivedHealth": {
          "type": "string",
          "minLength": 1,
          "description": "Formulaic health pool for the entity (e.g. twice combined physical H.P. and S.D.C.)."
        },
        "combatModifiers": {
          "description": "Flat integer strike/parry/dodge penalties or bonuses specific to the entity.",
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresenceConstructCombatModifiers"
        },
        "statModifiers": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresenceConstructStatModifiers"
        },
        "movement": {
          "$ref": "https://megaverse-companion.local/schemas/palladium-feature-common.schema.json#/$defs/spawnedPresenceConstructMovement"
        }
      }
    },
    "psionicInflictedCombatModifiers": {
      "type": "object",
      "description": "Combat penalties applied to the target while the debuff or condition is active.",
      "additionalProperties": true,
      "properties": {
        "strike": { "type": "integer" },
        "parry": { "type": "integer" },
        "dodge": { "type": "integer" },
        "speedMultiplier": { "type": "number" },
        "attacksPerMelee": { "type": "integer" }
      }
    },
    "psionicInflictedModifiers": {
      "type": "object",
      "additionalProperties": false,
      "description": "Debuffs and conditions applied to targets by offensive psionic powers.",
      "properties": {
        "statusEffects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "description": "Condition tags applied to the target (e.g. blind, stun, paralyzed)."
        },
        "combatModifiers": {
          "$ref": "#/$defs/psionicInflictedCombatModifiers"
        }
      }
    },
    "psionicGrantedCombatModifiers": {
      "type": "object",
      "description": "Temporary combat bonuses, penalties, and saving throw modifiers applied to the psychic while the power is active (e.g. Sixth Sense initiative, Summon Inner Strength save vs poison).",
      "additionalProperties": true,
      "properties": {
        "strike": { "type": "integer" },
        "parry": { "type": "integer" },
        "dodge": { "type": "integer" },
        "saveMagic": { "type": "integer" },
        "savePsionics": { "type": "integer" }
      }
    },
    "psionicGrantedStatModifiers": {
      "type": "object",
      "description": "Temporary attribute or health pool buffs applied to the psychic while the power is active (e.g. +10 S.D.C. from Summon Inner Strength).",
      "additionalProperties": true,
      "properties": {
        "sdc": { "type": "integer" },
        "hp": { "type": "integer" },
        "ps": { "type": "integer" }
      }
    },
    "psionicGrantedModifierTarget": {
      "type": "string",
      "enum": ["self", "touch", "line_of_sight", "area", "other"],
      "description": "Who receives immunities, stat modifiers, combat modifiers, and movement from grantedModifiers. Defaults to `self` when omitted."
    },
    "psionicGrantedModifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "$ref": "#/$defs/psionicGrantedModifierTarget"
        },
        "immunities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "description": "Damage types or effect categories the recipient ignores while the power is active."
        },
        "movement": {
          "type": "object",
          "description": "Temporary movement capabilities granted to the recipient while active (e.g. flightSpeed, hover).",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "combatModifiers": {
          "$ref": "#/$defs/psionicGrantedCombatModifiers"
        },
        "statModifiers": {
          "$ref": "#/$defs/psionicGrantedStatModifiers"
        }
      }
    },
    "psionicActivation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cost": { "$ref": "#/$defs/activationCost" },
        "range": { "type": "string", "minLength": 1 },
        "duration": { "type": "string", "minLength": 1 },
        "save": { "type": "string", "minLength": 1 }
      }
    },
    "activationCost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["isp", "ppe", "action", "other", "none"]
        },
        "value": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "pumpRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capPerLevel", "energyPerDice", "diceSides"],
      "properties": {
        "capPerLevel": { "type": "integer", "minimum": 0 },
        "energyPerDice": { "type": "integer", "minimum": 1 },
        "diceSides": { "type": "integer", "minimum": 2 }
      }
    },
    "psionicPrerequisite": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "psionic",
            "attribute_minimum",
            "level_minimum",
            "other_psionic_any_of",
            "diagnosis_before_surgery"
          ]
        },
        "psionicId": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "psionicIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "uniqueItems": true
        },
        "attribute": {
          "type": "string",
          "enum": ["iq", "me", "ma", "ps", "pp", "pe", "pb", "spd"]
        },
        "minimum": { "type": "integer", "minimum": 1 },
        "level": { "type": "integer", "minimum": 1, "maximum": 15 },
        "label": { "type": "string", "minLength": 1 }
      }
    }
  }
}
